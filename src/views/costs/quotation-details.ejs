<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-file-earmark-text"></i> عرض السعر <%= quotation.quotation_number %></h2>
                <div>
                    <button id="printQuotationBtn" class="btn btn-outline-primary me-2" type="button">
                        <i class="bi bi-printer"></i> طباعة
                    </button>
                    <button id="exportQuotationPdfBtn" class="btn btn-success me-2">
                        <i class="bi bi-file-earmark-pdf"></i> تصدير PDF
                    </button>
                    <a href="/costs/quotations" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-right me-1"></i> العودة للعروض
                    </a>
                </div>
            </div>

            <!-- تحضير التنسيق والحسابات -->
            <% 
                const isSYP = (defaultCurrency && defaultCurrency.code === 'SYP');
                const fmt = (v) => {
                    if (v === null || v === undefined || v === '') return '0';
                    if (typeof v === 'string' && /^-?\d+(\.\d+)?$/.test(v.trim())) return v.trim();
                    const num = parseFloat(v);
                    if (isNaN(num)) return '0';
                    return isSYP ? String(Math.round(num)) : num.toFixed(2);
                };
                let grandTotal = 0;
                
                (items || []).forEach(it => {
                    // استخدام القيم المحفوظة مباشرة بدلاً من إعادة حسابها
                    const unit = parseFloat(it.unit_cost) || 0;
                    const finalPrice = parseFloat(it.final_price) || 0;
                    const total = parseFloat(it.total_price) || 0;
                    grandTotal += total;
                });
	            %>
	            <input type="hidden" id="quotationGrandTotalValue" value="<%= (parseFloat(grandTotal) || 0) %>">

	            <!-- تفاصيل العرض -->
            <div class="card shadow mb-4">
                                <div id="quotationOutputModeModal" class="modal fade" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-sliders2 me-2 text-primary"></i> اختر نوع الإخراج</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                            </div>
                            <div class="modal-body">
                                <p class="mb-3">اختر النمط المطلوب:</p>
                                <div class="mb-3">
                                    <label for="quotationDiscountedTotalInput" class="form-label">الإجمالي بعد الخصم</label>
                                    <input id="quotationDiscountedTotalInput" type="number" min="0" step="0.01" class="form-control" />
                                    <small class="text-muted d-block mt-1">سيتم احتساب الخصم = الإجمالي الحالي - القيمة المدخلة.</small>
                                </div>
                                <div class="d-grid gap-2">
                                    <button id="quotationModeNormalBtn" type="button" class="btn btn-outline-secondary">
                                        عادي (النمط الحالي)
                                    </button>
                                    <button id="quotationModeFullBtn" type="button" class="btn btn-outline-primary">
                                        كامل (يتضمن كلفة الطرد + نسبة الربح)
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>                <!-- PDF Export Modal -->
                <div id="quotationPdfExportModal" class="modal fade" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-file-earmark-pdf me-2 text-success"></i> تم إنشاء ملف PDF</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                            </div>
                            <div class="modal-body text-center">
                                <div class="mb-3">
                                    <input type="text" id="quotationPdfLinkInput" class="form-control text-center" readonly style="direction:ltr; font-size:0.95em;" />
                                </div>
                                <div class="d-flex justify-content-center gap-2 mb-2">
                                    <button id="copyQuotationPdfLinkBtn" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard me-1"></i> نسخ الرابط</button>
                                    <a id="openQuotationPdfLinkBtn" class="btn btn-outline-info btn-sm" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i> فتح الرابط</a>
                                    <a id="whatsappQuotationShareBtn" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-whatsapp me-1"></i> ارسال عبر واتساب</a>
                                </div>
                                <div class="alert alert-success py-2 mb-0">يمكنك مشاركة الرابط مع أي شخص لتحميل عرض السعر مباشرة</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-header">
                    <h5 class="mb-0">تفاصيل العرض</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless no-auto-num-center">
                                <tr>
                                    <td><strong>رقم العرض:</strong></td>
                                    <td><%= quotation.quotation_number %></td>
                                </tr>
                                <tr>
                                    <td><strong>التاريخ:</strong></td>
                                    <td><%= formatDate(quotation.created_at) %></td>
                                </tr>
                                <tr>
                                    <td><strong>اسم العميل:</strong></td>
                                    <td><%= quotation.client_name %></td>
                                </tr>
                                <tr>
                                    <td><strong>رقم الهاتف:</strong></td>
                                    <td><%= quotation.client_phone || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>العنوان:</strong></td>
                                    <td><%= quotation.client_address || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>صفة البيع:</strong></td>
                                    <td><%= quotation.sale_description || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>طريقة الدفع:</strong></td>
                                    <td><%= quotation.payment_method || '-' %></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless no-auto-num-center">
                                
                                <tr>
                                    <td><strong>المبلغ الإجمالي:</strong></td>
                                    <td><strong class="text-primary">
                                        <%= fmt(grandTotal) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </strong></td>
                                </tr>
                                <tr>
                                    <td><strong>عدد المواد:</strong></td>
                                    <td><%= items.length %></td>
                                </tr>
                                <tr>
                                    <td><strong>ملاحظات:</strong></td>
                                    <td><%= quotation.notes || '-' %></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- جدول المواد -->
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0">المواد المطلوبة</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>رقم المادة</th>
                                    <th>الصنف</th>
                                    <th>نوع الصنف</th>
                                    <th>التعبئة</th>
                                    <th>حجم العبوة (كغ)</th>
                                    <th>شد الكرتون</th>
                                    <th>كلفة الطرد</th>
                                    <th>نسبة الربح</th>
                                    <th>السعر النهائي</th>
                                    <th>الكمية</th>
                                    <th>المجموع</th>
                                    <th>ملاحظات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <%
                                    const groupedQuotationItemsMap = new Map();
                                    (items || []).forEach((it) => {
                                        const key = (it.material_name || '').trim();
                                        if (!groupedQuotationItemsMap.has(key)) groupedQuotationItemsMap.set(key, []);
                                        groupedQuotationItemsMap.get(key).push(it);
                                    });
                                    const groupedQuotationItems = Array.from(groupedQuotationItemsMap.values());
                                %>
                                <% groupedQuotationItems.forEach((group) => { %>
                                <% group.forEach((item, indexInGroup) => {
                                     const unit = item.unit_cost;
                                     const final = item.final_price;
                                     const total = item.total_price;
                                %>
                                <tr>
                                    <td><%= item.material_id || '-' %></td>
                                    <% if (indexInGroup === 0) { %>
                                    <td rowspan="<%= group.length %>"><%= item.material_name %></td>
                                    <% } %>
                                    <td><%= item.material_type || '-' %></td>
                                    <td><%= item.packaging_unit || '-' %></td>
                                    <td>
                                        <% if (item.packaging_weight != null) { %>
                                            <%= fmt(item.packaging_weight) %>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                    <td><%= item.pieces_per_package || '-' %></td>
                                    <td>
                                        <%= fmt(unit) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                    <td><%= fmt(item.profit_percentage) %>%</td>
                                    <td>
                                        <%= fmt(final) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                    <td><%= item.quantity %></td>
                                    <td>
                                        <strong><%= fmt(total) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></strong>
                                    </td>
                                    <td><%= item.item_notes || '-' %></td>
                                </tr>
                                <% }); %>
                                <% }); %>
                            </tbody>
                            <tfoot>
                                <tr class="table-info">
                                    <td colspan="10" class="text-end"><strong>المجموع الإجمالي:</strong></td>
                                    <td><strong>
                                        <%= fmt(grandTotal) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </strong></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ملاحظات إضافية -->
            <% if (quotation.notes) { %>
            <div class="card shadow mt-4">
                <div class="card-header">
                    <h5 class="mb-0">ملاحظات</h5>
                </div>
                <div class="card-body">
                    <p><%= quotation.notes %></p>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const printBtn = document.getElementById('printQuotationBtn');
    const exportBtn = document.getElementById('exportQuotationPdfBtn');
    const quotationGrandTotal = Number(document.getElementById('quotationGrandTotalValue')?.value || 0);
    const outputModeModalElem = document.getElementById('quotationOutputModeModal');
    const outputModeModal = outputModeModalElem ? new bootstrap.Modal(outputModeModalElem) : null;
    const modeNormalBtn = document.getElementById('quotationModeNormalBtn');
    const modeFullBtn = document.getElementById('quotationModeFullBtn');
    const discountedTotalInput = document.getElementById('quotationDiscountedTotalInput');
    const modalElem = document.getElementById('quotationPdfExportModal');
    const modal = modalElem ? new bootstrap.Modal(modalElem) : null;
    const linkInput = document.getElementById('quotationPdfLinkInput');
    const copyBtn = document.getElementById('copyQuotationPdfLinkBtn');
    const openBtn = document.getElementById('openQuotationPdfLinkBtn');
    const waBtn = document.getElementById('whatsappQuotationShareBtn');

    let pendingOutputAction = null;

    function openOutputModeChooser(action) {
        pendingOutputAction = action;
        if (discountedTotalInput) {
            discountedTotalInput.value = quotationGrandTotal.toFixed(2);
        }
        if (outputModeModal) outputModeModal.show();
    }

    function getValidatedDiscountedTotal() {
        if (!discountedTotalInput) return quotationGrandTotal;
        const rawValue = parseFloat(discountedTotalInput.value);
        if (!Number.isFinite(rawValue)) {
            alert('يرجى إدخال قيمة رقمية صحيحة.');
            discountedTotalInput.focus();
            return null;
        }
        if (rawValue < 0) {
            alert('قيمة الإجمالي بعد الخصم يجب أن تكون صفر أو أكبر.');
            discountedTotalInput.focus();
            return null;
        }
        if (rawValue > quotationGrandTotal) {
            alert('لا يمكن أن يكون الإجمالي بعد الخصم أكبر من الإجمالي الحالي.');
            discountedTotalInput.focus();
            return null;
        }
        return rawValue;
    }

    async function exportPdfByMode(mode, discountedTotalValue) {
        if (!exportBtn) return;
            exportBtn.disabled = true;
            exportBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> جاري التصدير...';
            try {
            const res = await fetch(`/costs/quotations/<%= quotation.id %>/pdf?mode=${encodeURIComponent(mode)}&discounted_total=${encodeURIComponent(discountedTotalValue)}`);
                const data = await res.json();
                if (data.success && data.url) {
                    if (linkInput) linkInput.value = data.url;
                    if (openBtn) openBtn.href = data.url;
                    if (waBtn) waBtn.href = `https://wa.me/?text=${encodeURIComponent(data.url)}`;
                    if (modal) modal.show();
                } else {
                    alert(data.message || 'حدث خطأ أثناء توليد ملف PDF');
                }
            } catch (e) {
                alert('حدث خطأ في الاتصال بالخادم');
            }
            exportBtn.disabled = false;
            exportBtn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> تصدير PDF';
    }

    function printByMode(mode, discountedTotalValue) {
        window.open(`/costs/quotations/<%= quotation.id %>/print?mode=${encodeURIComponent(mode)}&discounted_total=${encodeURIComponent(discountedTotalValue)}`, '_blank');
    }

    async function handleModeSelection(mode) {
        const discountedTotalValue = getValidatedDiscountedTotal();
        if (discountedTotalValue === null) return;
        if (outputModeModal) outputModeModal.hide();
        if (pendingOutputAction === 'print') {
            printByMode(mode, discountedTotalValue);
            return;
        }
        if (pendingOutputAction === 'export') {
            await exportPdfByMode(mode, discountedTotalValue);
        }
    }

    if (printBtn) {
        printBtn.addEventListener('click', function () {
            openOutputModeChooser('print');
        });
    }
    if (exportBtn) {
        exportBtn.addEventListener('click', function () {
            openOutputModeChooser('export');
        });
    }
    if (modeNormalBtn) {
        modeNormalBtn.addEventListener('click', function () {
            handleModeSelection('normal');
        });
    }
    if (modeFullBtn) {
        modeFullBtn.addEventListener('click', function () {
            handleModeSelection('full');
        });
    }
    if (copyBtn && linkInput) {
        copyBtn.addEventListener('click', function () {
            linkInput.select();
            document.execCommand('copy');
        });
    }
});
</script>
<style>
@media print {
    .btn, .no-print {
        display: none !important;
    }
    
    .card {
        border: 1px solid #000 !important;
        box-shadow: none !important;
    }
    
    .card-header {
        background-color: #f8f9fa !important;
        border-bottom: 1px solid #000 !important;
    }
    
    body {
        font-size: 12px;
    }
    
    .table {
        font-size: 11px;
    }
    
    .table th, .table td {
        padding: 4px;
    }
}
</style> 

