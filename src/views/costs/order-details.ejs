<% function formatDate(dateString){
  if (!dateString) return '-';
  const date = new Date(dateString);
  const day = String(date.getDate()).padStart(2,'0');
  const month = String(date.getMonth()+1).padStart(2,'0');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
}

function formatNumberDisplay(value) {
  if (value === null || value === undefined || value === '') return '-';
  if (typeof value === 'string' && /^-?\d+(\.\d+)?$/.test(value.trim())) return value.trim();
  const num = (typeof value === 'number') ? value : parseFloat(value);
  if (!Number.isFinite(num)) return '-';
  if (num === 0 || Object.is(num, -0)) return '0';
  const safe = Number(num.toFixed(12));
  let out = Number.isInteger(safe) ? String(safe) : safe.toString();
  out = out.replace(/(\.\d*?[1-9])0+$/,'$1').replace(/\.0+$/,'');
  if (out === '-0') out = '0';
  return safe < 0 ? ('\u200E' + out) : out;
}
function formatTotalDisplay(value) {
  const num = parseFloat(value);
  if (!Number.isFinite(num)) return '0';
  const normalized = Number.isInteger(num)
    ? String(num)
    : num.toFixed(6).replace(/0+$/,'').replace(/\.$/,'');
  const neg = normalized.startsWith('-');
  const clean = neg ? normalized.slice(1) : normalized;
  const [intPart, fracPart] = clean.split('.');
  const grouped = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  const out = grouped + (fracPart ? `.${fracPart}` : '');
  return neg ? ('\u200E-' + out) : out;
} %>

<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-earmark-text"></i> تفاصيل الطلبية <%= order.order_number %></h2>
        <div>
          <button id="printOrderBtn" class="btn btn-outline-primary me-2 no-print" data-bs-toggle="modal" data-bs-target="#printTypeModal">
            <i class="bi bi-printer"></i> طباعة
          </button>
          <button id="exportOrderBtn" class="btn btn-success me-2 no-print" data-bs-toggle="modal" data-bs-target="#exportTypeModal">
            <i class="bi bi-file-earmark-pdf"></i> تصدير PDF
          </button>
          <a href="/costs/orders" class="btn btn-outline-secondary no-print">
            <i class="bi bi-arrow-right me-1"></i> العودة للطلبيات
          </a>
        </div>
      </div>
      <input type="hidden" id="orderGrandTotalValue" value="<%= (typeof totals !== 'undefined' && totals ? (totals.grandTotal ?? 0) : 0) %>">

      <!-- PDF Export Modal -->
      <div id="orderPdfExportModal" class="modal fade" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title"><i class="bi bi-file-earmark-pdf me-2 text-success"></i> تم إنشاء ملف PDF</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body text-center">
              <div class="mb-3">
                <input type="text" id="orderPdfLinkInput" class="form-control text-center" readonly style="direction:ltr; font-size:0.95em;" />
              </div>
              <div class="d-flex justify-content-center gap-2 mb-2">
                <button id="copyOrderPdfLinkBtn" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard me-1"></i> نسخ الرابط</button>
                <a id="openOrderPdfLinkBtn" class="btn btn-outline-info btn-sm" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i> فتح الرابط</a>
                <a id="whatsappOrderShareBtn" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-whatsapp me-1"></i> ارسال عبر واتساب</a>
              </div>
              <div class="alert alert-success py-2 mb-0">يمكنك مشاركة الرابط مع أي شخص لتحميل الطلبية مباشرة</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow mb-4">
        <div class="card-header">
          <h5 class="mb-0">معلومات الطلبية</h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <table class="table table-borderless no-auto-num-center">
                <tr>
                  <td><strong>رقم الطلبية:</strong></td>
                  <td><%= order.order_number %></td>
                </tr>
                <tr>
                  <td><strong>اسم الزبون:</strong></td>
                  <td><%= order.client_name || '-' %></td>
                </tr>
                <tr>
                  <td><strong>اسم المستلم:</strong></td>
                  <td><%= order.recipient_name || '-' %></td>
                </tr>
                <tr>
                  <td><strong>تاريخ الطلبية:</strong></td>
                  <td><%= formatDate(order.order_date) %></td>
                </tr>
                <tr>
                  <td><strong>تاريخ التسليم:</strong></td>
                  <td><%= formatDate(order.delivery_date) %></td>
                </tr>
                <tr>
                  <td><strong>الحالة:</strong></td>
                  <td>
                    <span class="badge bg-<%= 
                      order.status === 'pending' ? 'warning' : 
                      order.status === 'processing' ? 'info' : 
                      order.status === 'completed' ? 'success' : 'danger' 
                    %>">
                      <%= 
                        order.status === 'pending' ? 'قيد الانتظار' :
                        order.status === 'processing' ? 'قيد المعالجة' :
                        order.status === 'completed' ? 'مكتمل' : 'ملغي'
                      %>
                    </span>
                  </td>
                </tr>
              </table>
            </div>
            <div class="col-md-6">
              <table class="table table-borderless no-auto-num-center">
                <tr>
                  <td><strong>المسؤول عن التجهيز:</strong></td>
                  <td><%= order.responsible_worker || '-' %></td>
                </tr>
                <tr>
                  <td><strong>مراقب الجودة:</strong></td>
                  <td><%= order.quality_controller || '-' %></td>
                </tr>
                <tr>
                  <td><strong>عدد الطبالي:</strong></td>
                  <td><%= order.pallets_count != null ? formatNumberDisplay(order.pallets_count) : '-' %></td>
                </tr>
                <tr>
                  <td><strong>رقم الحاوية:</strong></td>
                  <td><%= order.container_number || '-' %></td>
                </tr>
                <tr>
                  <td><strong>عدد الطرود:</strong></td>
                  <td><%= order.packages_count != null ? formatNumberDisplay(order.packages_count) : '-' %></td>
                </tr>
                <tr>
                  <td><strong>رقم البوليصة:</strong></td>
                  <td><%= order.waybill_number || '-' %></td>
                </tr>
                <tr>
                  <td><strong>رقم الاعتماد:</strong></td>
                  <td><%= order.accreditation_number || '-' %></td>
                </tr>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow">
        <div class="card-header">
          <h5 class="mb-0">مواد الطلبية</h5>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-bordered">
              <thead>
                <tr>
                  <th>رقم المادة</th>
                  <th>اسم المادة</th>
                  <th>التعبئة</th>
                  <th>الكمية المطلوبة</th>
                  <th>وزن التعبئة</th>
                  <th>شد الكرتون</th>
                  <th>وزن الطرد القائم</th>
                  <th>سعر الطرد</th>
                  <th>السعر الإجمالي</th>
                  <th>ملاحظات</th>
                </tr>
              </thead>
              <tbody>
                <%
                  const groupedOrderItemsMap = new Map();
                  (items || []).forEach((it) => {
                    const key = (it.material_name || '').trim();
                    if (!groupedOrderItemsMap.has(key)) groupedOrderItemsMap.set(key, []);
                    groupedOrderItemsMap.get(key).push(it);
                  });
                  const groupedOrderItems = Array.from(groupedOrderItemsMap.values());
                %>
                <% groupedOrderItems.forEach((group) => { %>
                <% group.forEach((item, indexInGroup) => { %>
                  <tr>
                    <td><%= item.material_id || '-' %></td>
                    <% if (indexInGroup === 0) { %>
                    <td rowspan="<%= group.length %>"><%= item.material_name || '-' %></td>
                    <% } %>
                    <td><%= item.unit || '-' %></td>
                    <td><%= item.requested_quantity != null ? formatNumberDisplay(item.requested_quantity) : '-' %></td>
                    <td><%= item.packaging_weight != null ? formatNumberDisplay(item.packaging_weight) : '-' %></td>
                    <td><%= item.pieces_per_package != null ? formatNumberDisplay(item.pieces_per_package) : '-' %></td>
                    <td><%= item.gross_weight != null ? formatNumberDisplay(item.gross_weight) : '-' %></td>
                    <td><%= (typeof item.unit_price !== 'undefined') ? formatNumberDisplay(item.unit_price) : '-' %> <%= (typeof defaultCurrency !== 'undefined' && defaultCurrency && defaultCurrency.symbol) ? defaultCurrency.symbol : '' %></td>
                    <td><%= (typeof item.total_price !== 'undefined') ? formatNumberDisplay(item.total_price) : '-' %> <%= (typeof defaultCurrency !== 'undefined' && defaultCurrency && defaultCurrency.symbol) ? defaultCurrency.symbol : '' %></td>
                    <td><%= item.notes || '-' %></td>
                  </tr>
                <% }) %>
                <% }) %>
              </tbody>
              <tfoot>
                <tr class="table-info">
                  <td colspan="3" class="text-center"><strong>الإجماليات</strong></td>
                  <td><strong><%= typeof totals !== 'undefined' && totals ? formatTotalDisplay(totals.totalRequestedQuantity) : '0' %></strong></td>
                  <td><strong><%= typeof totals !== 'undefined' && totals ? formatTotalDisplay(totals.totalPackagingWeight) : '0' %></strong></td>
                  <td></td>
                  <td><strong><%= typeof totals !== 'undefined' && totals ? formatTotalDisplay(totals.totalGrossWeight || 0) : '0' %></strong></td>
                  <td></td>
                  <td><strong><%= typeof totals !== 'undefined' && totals ? formatTotalDisplay(totals.grandTotal) : '0' %> <%= (typeof defaultCurrency !== 'undefined' && defaultCurrency && defaultCurrency.symbol) ? defaultCurrency.symbol : '' %></strong></td>
                  <td></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>

      <% if (order.notes) { %>
      <div class="card shadow mt-4">
        <div class="card-header">
          <h5 class="mb-0">ملاحظات</h5>
        </div>
        <div class="card-body">
          <p><%= order.notes %></p>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
function formatDate(dateString){
  if (!dateString) return '-';
  const date = new Date(dateString);
  const day = String(date.getDate()).padStart(2,'0');
  const month = String(date.getMonth()+1).padStart(2,'0');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
}
</script>

<style>
@media print {
  .no-print { display: none !important; }
  .card { border: 1px solid #000 !important; box-shadow: none !important; }
  .card-header { background-color: #f8f9fa !important; border-bottom: 1px solid #000 !important; }
  body { font-size: 12px; }
  .table { font-size: 11px; }
  .table th, .table td { padding: 4px; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function(){
  const linkInput = document.getElementById('orderPdfLinkInput');
  const copyBtn = document.getElementById('copyOrderPdfLinkBtn');
  if (copyBtn && linkInput) {
    copyBtn.addEventListener('click', function(){ linkInput.select(); document.execCommand('copy'); });
  }
});

// Print and Export Functions
function printAsOrder() {
  const discountedTotalValue = getValidatedOrderDiscountedTotal('printDiscountedTotalInput', 'printDiscountType');
  if (discountedTotalValue === null) return;
  const lang = document.getElementById('printLanguageSelect')?.value || 'ar';
  window.open(`/costs/orders/<%= order.id %>/print?discounted_total=${encodeURIComponent(discountedTotalValue)}&lang=${encodeURIComponent(lang)}`, '_blank');
  bootstrap.Modal.getInstance(document.getElementById('printTypeModal')).hide();
}

function printAsInvoice() {
  const discountedTotalValue = getValidatedOrderDiscountedTotal('printDiscountedTotalInput', 'printDiscountType');
  if (discountedTotalValue === null) return;
  const lang = document.getElementById('printLanguageSelect')?.value || 'ar';
  window.open(`/costs/orders/<%= order.id %>/print?type=invoice&discounted_total=${encodeURIComponent(discountedTotalValue)}&lang=${encodeURIComponent(lang)}`, '_blank');
  bootstrap.Modal.getInstance(document.getElementById('printTypeModal')).hide();
}

async function exportAsOrder() {
  const discountedTotalValue = getValidatedOrderDiscountedTotal('exportDiscountedTotalInput', 'exportDiscountType');
  if (discountedTotalValue === null) return;
  const lang = document.getElementById('exportLanguageSelect')?.value || 'ar';
  bootstrap.Modal.getInstance(document.getElementById('exportTypeModal')).hide();
  await exportPDF(`/costs/orders/<%= order.id %>/pdf?discounted_total=${encodeURIComponent(discountedTotalValue)}&lang=${encodeURIComponent(lang)}`);
}

async function exportAsInvoice() {
  const discountedTotalValue = getValidatedOrderDiscountedTotal('exportDiscountedTotalInput', 'exportDiscountType');
  if (discountedTotalValue === null) return;
  const lang = document.getElementById('exportLanguageSelect')?.value || 'ar';
  bootstrap.Modal.getInstance(document.getElementById('exportTypeModal')).hide();
  await exportPDF(`/costs/orders/<%= order.id %>/pdf?type=invoice&discounted_total=${encodeURIComponent(discountedTotalValue)}&lang=${encodeURIComponent(lang)}`);
}

function getValidatedOrderDiscountedTotal(inputId, typeId) {
  enforceOrderDiscountLimits(inputId, typeId);
  const total = Number(document.getElementById('orderGrandTotalValue')?.value || 0);
  const input = document.getElementById(inputId);
  const typeSelect = document.getElementById(typeId);
  if (!input) return total;
  const rawValue = parseFloat(input.value);
  const mode = typeSelect ? typeSelect.value : 'fixed';

  if (!Number.isFinite(rawValue)) {
    alert('يرجى إدخال قيمة رقمية صحيحة.');
    input.focus();
    return null;
  }

  let discountAmount = 0;
  if (mode === 'percent') {
    if (rawValue < 0 || rawValue > 100) {
      alert('النسبة المئوية يجب أن تكون بين 0 و 100.');
      input.focus();
      return null;
    }
    discountAmount = (total * rawValue) / 100;
  } else {
    if (rawValue < 0) {
      alert('قيمة الخصم الثابت لا يمكن أن تكون أقل من صفر.');
      input.focus();
      return null;
    }
    if (rawValue > total) {
      alert('قيمة الخصم الثابت لا يمكن أن تكون أكبر من الإجمالي الحالي.');
      input.focus();
      return null;
    }
    discountAmount = rawValue;
  }

  return Math.max(0, total - discountAmount);
}

function enforceOrderDiscountLimits(inputId, typeId) {
  const total = Number(document.getElementById('orderGrandTotalValue')?.value || 0);
  const input = document.getElementById(inputId);
  const typeSelect = document.getElementById(typeId);
  if (!input) return;

  const mode = typeSelect ? typeSelect.value : 'fixed';
  const raw = (input.value || '').trim();
  if (!raw) return;
  let value = parseFloat(raw);
  if (!Number.isFinite(value)) return;
  if (value < 0) value = 0;
  if (mode === 'percent') {
    if (value > 100) value = 100;
  } else {
    if (value > total) value = total;
  }
  if (String(value) !== raw) {
    input.value = String(value);
  }
}

function initializeOrderDiscountInputs() {
  const total = Number(document.getElementById('orderGrandTotalValue')?.value || 0);
  const printInput = document.getElementById('printDiscountedTotalInput');
  const exportInput = document.getElementById('exportDiscountedTotalInput');
  const printType = document.getElementById('printDiscountType');
  const exportType = document.getElementById('exportDiscountType');
  if (printType) printType.value = 'fixed';
  if (exportType) exportType.value = 'fixed';
  if (printInput) printInput.value = '0';
  if (exportInput) exportInput.value = '0';
  updateOrderDiscountHelper('printDiscountedTotalInput', 'printDiscountType', 'printDiscountHelper');
  updateOrderDiscountHelper('exportDiscountedTotalInput', 'exportDiscountType', 'exportDiscountHelper');
}

function updateOrderDiscountHelper(inputId, typeId, helperId) {
  const total = Number(document.getElementById('orderGrandTotalValue')?.value || 0);
  const input = document.getElementById(inputId);
  const typeSelect = document.getElementById(typeId);
  const helper = document.getElementById(helperId);
  if (!input || !helper) return;
  enforceOrderDiscountLimits(inputId, typeId);

  const rawValue = parseFloat(input.value || '0');
  const numericValue = Number.isFinite(rawValue) ? rawValue : 0;
  const mode = typeSelect ? typeSelect.value : 'fixed';

  let discountAmount = 0;
  if (mode === 'percent') {
    discountAmount = Math.max(0, Math.min(100, numericValue)) * total / 100;
  } else {
    discountAmount = Math.max(0, Math.min(total, numericValue));
  }
  const afterDiscount = Math.max(0, total - discountAmount);

  if (mode === 'percent') {
    helper.textContent = `سيتم خصم ${numericValue}% من الإجمالي الحالي، أي خصم ${discountAmount.toFixed(2)}، ليصبح الإجمالي بعد الخصم ${afterDiscount.toFixed(2)}.`;
  } else {
    helper.textContent = `سيتم خصم قيمة ثابتة مقدارها ${discountAmount.toFixed(2)} من الإجمالي الحالي، ليصبح الإجمالي بعد الخصم ${afterDiscount.toFixed(2)}.`;
  }
}

document.addEventListener('DOMContentLoaded', function () {
  initializeOrderDiscountInputs();
  const printModalEl = document.getElementById('printTypeModal');
  const exportModalEl = document.getElementById('exportTypeModal');
  const printInput = document.getElementById('printDiscountedTotalInput');
  const exportInput = document.getElementById('exportDiscountedTotalInput');
  const printType = document.getElementById('printDiscountType');
  const exportType = document.getElementById('exportDiscountType');
  if (printModalEl) printModalEl.addEventListener('show.bs.modal', initializeOrderDiscountInputs);
  if (exportModalEl) exportModalEl.addEventListener('show.bs.modal', initializeOrderDiscountInputs);
  if (printInput) printInput.addEventListener('input', () => updateOrderDiscountHelper('printDiscountedTotalInput', 'printDiscountType', 'printDiscountHelper'));
  if (exportInput) exportInput.addEventListener('input', () => updateOrderDiscountHelper('exportDiscountedTotalInput', 'exportDiscountType', 'exportDiscountHelper'));
  if (printType) printType.addEventListener('change', () => {
    if (printType.value === 'percent') {
      printInput?.setAttribute('max', '100');
    } else {
      printInput?.setAttribute('max', String(Number(document.getElementById('orderGrandTotalValue')?.value || 0)));
    }
    updateOrderDiscountHelper('printDiscountedTotalInput', 'printDiscountType', 'printDiscountHelper');
  });
  if (exportType) exportType.addEventListener('change', () => {
    if (exportType.value === 'percent') {
      exportInput?.setAttribute('max', '100');
    } else {
      exportInput?.setAttribute('max', String(Number(document.getElementById('orderGrandTotalValue')?.value || 0)));
    }
    updateOrderDiscountHelper('exportDiscountedTotalInput', 'exportDiscountType', 'exportDiscountHelper');
  });
  if (printInput && printType && printType.value === 'percent') printInput.setAttribute('max', '100');
  if (exportInput && exportType && exportType.value === 'percent') exportInput.setAttribute('max', '100');
});

async function exportPDF(url) {
  const exportBtn = document.getElementById('exportOrderBtn');
  exportBtn.disabled = true;
  exportBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> جاري التصدير...';
  
  try {
    const res = await fetch(url);
    const data = await res.json();
    if (data.success && data.url) {
      const linkInput = document.getElementById('orderPdfLinkInput');
      const openBtn = document.getElementById('openOrderPdfLinkBtn');
      const waBtn = document.getElementById('whatsappOrderShareBtn');
      const modal = new bootstrap.Modal(document.getElementById('orderPdfExportModal'));
      
      if (linkInput) linkInput.value = data.url;
      if (openBtn) openBtn.href = data.url;
      if (waBtn) waBtn.href = `https://wa.me/?text=${encodeURIComponent(data.url)}`;
      if (modal) modal.show();
    } else {
      alert(data.message || 'حدث خطأ أثناء توليد ملف PDF');
    }
  } catch (e) {
    alert('حدث خطأ في الاتصال بالخادم');
  }
  
  exportBtn.disabled = false;
  exportBtn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> تصدير PDF';
}
</script>

<!-- Print Type Selection Modal -->
<div class="modal fade" id="printTypeModal" tabindex="-1" aria-labelledby="printTypeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="printTypeModalLabel">
          <i class="bi bi-printer me-2"></i> اختر نوع الطباعة
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="printDiscountType" class="form-label">نوع الخصم</label>
          <select id="printDiscountType" class="form-select">
            <option value="fixed">قيمة ثابتة</option>
            <option value="percent">نسبة مئوية</option>
          </select>
        </div>
        <div class="mb-3">
          <label for="printDiscountedTotalInput" class="form-label">قيمة الخصم</label>
          <input id="printDiscountedTotalInput" type="text" inputmode="decimal" min="0" step="0.01" class="form-control" />
          <small id="printDiscountHelper" class="text-muted d-block mt-1">عند اختيار "قيمة ثابتة": الرقم هو مبلغ خصم مباشر من الإجمالي الحالي.</small>
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <div class="card h-100 border-primary" style="cursor: pointer;" onclick="printAsOrder()">
              <div class="card-body text-center">
                <i class="bi bi-file-earmark-text text-primary" style="font-size: 2rem;"></i>
                <h6 class="card-title mt-2">طباعة كطلبية</h6>
                <p class="card-text text-muted small">طباعة الطلبية مع جميع بيانات الطلبية</p>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card h-100 border-success" style="cursor: pointer;" onclick="printAsInvoice()">
              <div class="card-body text-center">
                <i class="bi bi-receipt text-success" style="font-size: 2rem;"></i>
                <h6 class="card-title mt-2">طباعة كطلبية شحن</h6>
                <p class="card-text text-muted small">طباعة كطلبية شحن بدون بيانات الطلبية</p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-3">
          <label for="printLanguageSelect" class="form-label">لغة الطباعة</label>
          <select id="printLanguageSelect" class="form-select">
            <option value="ar" selected>العربية</option>
            <option value="en">English</option>
          </select>
          <small class="text-muted d-block mt-1">عند اختيار الإنكليزية سيتم ترجمة المحتوى العربي باستثناء الهيدر والفوتر.</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Export Type Selection Modal -->
<div class="modal fade" id="exportTypeModal" tabindex="-1" aria-labelledby="exportTypeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exportTypeModalLabel">
          <i class="bi bi-file-earmark-pdf me-2"></i> اختر نوع التصدير
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="exportDiscountType" class="form-label">نوع الخصم</label>
          <select id="exportDiscountType" class="form-select">
            <option value="fixed">قيمة ثابتة</option>
            <option value="percent">نسبة مئوية</option>
          </select>
        </div>
        <div class="mb-3">
          <label for="exportDiscountedTotalInput" class="form-label">قيمة الخصم</label>
          <input id="exportDiscountedTotalInput" type="text" inputmode="decimal" min="0" step="0.01" class="form-control" />
          <small id="exportDiscountHelper" class="text-muted d-block mt-1">عند اختيار "قيمة ثابتة": الرقم هو مبلغ خصم مباشر من الإجمالي الحالي.</small>
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <div class="card h-100 border-primary" style="cursor: pointer;" onclick="exportAsOrder()">
              <div class="card-body text-center">
                <i class="bi bi-file-earmark-text text-primary" style="font-size: 2rem;"></i>
                <h6 class="card-title mt-2">تصدير كطلبية</h6>
                <p class="card-text text-muted small">تصدير الطلبية مع جميع بيانات الطلبية</p>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card h-100 border-success" style="cursor: pointer;" onclick="exportAsInvoice()">
              <div class="card-body text-center">
                <i class="bi bi-receipt text-success" style="font-size: 2rem;"></i>
                <h6 class="card-title mt-2">تصدير كطلبية شحن</h6>
                <p class="card-text text-muted small">تصدير كطلبية شحن بدون بيانات الطلبية</p>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-3">
          <label for="exportLanguageSelect" class="form-label">لغة التصدير</label>
          <select id="exportLanguageSelect" class="form-select">
            <option value="ar" selected>العربية</option>
            <option value="en">English</option>
          </select>
          <small class="text-muted d-block mt-1">عند اختيار الإنكليزية سيتم ترجمة المحتوى العربي باستثناء الهيدر والفوتر.</small>
        </div>
      </div>
    </div>
  </div>
</div>




