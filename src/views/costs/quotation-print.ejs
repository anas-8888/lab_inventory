<% function fmtDate(d){ if(!d) return '-'; const dt=new Date(d); const dd=String(dt.getDate()).padStart(2,'0'); const mm=String(dt.getMonth()+1).padStart(2,'0'); const yy=dt.getFullYear(); return `${dd}/${mm}/${yy}`; }
function formatNumberDisplay(value) {
  if (value === null || value === undefined || value === '') return '-';
  // للأرقام النصية الصرفة، نعرضها كما أُدخلت دون إعادة تنسيق
  if (typeof value === 'string' && /^-?\d+(\.\d+)?$/.test(value.trim())) {
    return value.trim();
  }
  const num = parseFloat(value);
  if (isNaN(num)) return '-';
  if (num === 0) return '0';
  let result = '';
  if (Number.isInteger(num)) {
    // للأرقام الصحيحة، أضف 3 منازل عشرية
    result = num.toString();
  } else {
    const ds = num.toString().split('.')[1];
    if (!ds) {
      result = num.toString();
    } else {
      // احتفظ بالمنازل الموجودة مع حد أدنى 3
      result = num.toString();
    }
  }
  if (num < 0) return '\u200E' + result;
  return result;
}
function formatTotalDisplay(value) {
  const num = parseFloat(value);
  if (!Number.isFinite(num)) return '0';
  const normalized = Number.isInteger(num)
    ? String(num)
    : num.toFixed(6).replace(/0+$/,'').replace(/\.$/,'');
  const neg = normalized.startsWith('-');
  const clean = neg ? normalized.slice(1) : normalized;
  const [intPart, fracPart] = clean.split('.');
  const grouped = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  const out = grouped + (fracPart ? `.${fracPart}` : '');
  return neg ? ('\u200E-' + out) : out;
}
function formatDiscountDisplay(value) {
  const num = parseFloat(value);
  if (isNaN(num)) return '0.00';
  const fixed = num.toFixed(2);
  const [intPart, fracPart] = fixed.split('.');
  const grouped = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  return `${grouped}.${fracPart}`;
}
const currencySymbol = (typeof defaultCurrency !== 'undefined' && defaultCurrency && defaultCurrency.symbol) ? defaultCurrency.symbol : '';
const isFullMode = !!showFullQuotationColumns;
const quotationTableColumnCount = isFullMode ? 11 : 9;
const quotationTotalLabelColspan = isFullMode ? 9 : 7;
const totalBeforeDiscount = parseFloat(grandTotal) || 0;
const totalAfterDiscount = (typeof discountedTotal !== 'undefined' && discountedTotal !== null)
  ? (parseFloat(discountedTotal) || 0)
  : totalBeforeDiscount;
const discountValue = (typeof discountAmount !== 'undefined' && discountAmount !== null)
  ? Math.max(0, parseFloat(discountAmount) || 0)
  : Math.max(0, totalBeforeDiscount - totalAfterDiscount);
const hasDiscount = discountValue > 0;
%>

<div class="container-fluid" style="direction: rtl; font-family: 'Cairo','Amiri',sans-serif;">
  <!-- Header -->
  <table style="width: 100%; border-collapse: collapse; margin-top: 4px;">
    <tr>
      <td style="text-align: right; font-weight: bold; line-height: 1.2; width: 37%; font-size: 9pt;">
        <div>مؤسسة عجاج أخوان التجارية</div>
        <div>لإنتاج وتعبئة المواد الغذائية</div>
        <div>وتجارة زيت الزيتون البكر</div>
        <div style="font-size: 12px;">س.ت 10369 – س.ص 10</div>
      </td>
      <td style="text-align: center; width: 26%;">
        <img src="/public/images/nexa.png" alt="شعار" style="width: 70px; height: 70px;">
      </td>
      <td style="text-align: left; font-weight: bold; line-height: 1.2; width: 37%; font-size: 9pt;">
        <div>Ajaj Brothers Commercial Foundation</div>
        <div>For Food Production and Packaging</div>
        <div>And Virgin Olive Oil Trade</div>
        <div style="font-size: 12px;">C.R. 10369 – I.R. 10</div>
      </td>
    </tr>
  </table>
  <hr style="margin: 4px 0; border: 0.5px solid #bbb;">

  <!-- Title -->
  <div style="text-align:center; margin: 6px 0;">
    <div style="font-size: 11pt; font-weight: 700;">عرض سعر رقم (<%= quotation.quotation_number %>)</div>
  </div>

  <!-- Customer/Quotation Info -->
  <div class="info-grid">
    <div class="box-compact">
      <h6 class="section-title">بيانات العميل</h6>
      <div class="grid-kv">
        <div class="kv"><span>الاسم:</span><span><%= quotation.client_name ? ('السيد/ة ' + quotation.client_name + ' المحترم/ة') : '-' %></span></div>
        <% if (quotation.client_phone) { %><div class="kv"><span>الهاتف:</span><span><%= quotation.client_phone %></span></div><% } %>
        <% if (quotation.client_address) { %><div class="kv full"><span>العنوان:</span><span><%= quotation.client_address %></span></div><% } %>
        <% if (quotation.sale_description) { %><div class="kv"><span>صفة البيع:</span><span><%= quotation.sale_description %></span></div><% } %>
        <% if (quotation.payment_method) { %><div class="kv"><span>طريقة الدفع:</span><span><%= quotation.payment_method %></span></div><% } %>
      </div>
    </div>
    <div class="box-compact">
      <h6 class="section-title">بيانات العرض</h6>
      <div class="grid-kv">
        <div class="kv"><span>التاريخ:</span><span><%= fmtDate(quotation.created_at) %></span></div>
        <div class="kv"><span>عدد المواد:</span><span><%= (items||[]).length %></span></div>
          <div class="kv"><span>إجمالي السعر:</span><span class="money-inline"><%= `${formatTotalDisplay(totalBeforeDiscount)} ${currencySymbol}` %></span></div>
        <% if (hasDiscount) { %>
          <div class="kv"><span>الخصم:</span><span class="money-inline"><%= `- ${formatDiscountDisplay(discountValue)} ${currencySymbol}` %></span></div>
          <div class="kv"><span>الإجمالي بعد الخصم:</span><span class="money-inline"><%= `${formatDiscountDisplay(totalAfterDiscount)} ${currencySymbol}` %></span></div>
        <% } %>
      </div>
    </div>
    <% if (quotation.notes) { %>
      <div class="box-compact">
        <h6 class="section-title">ملاحظات</h6>
        <div class="notes"><%= quotation.notes %></div>
      </div>
    <% } %>
  </div>

  <!-- Items Table -->
  <div class="table-responsive" style="margin-top: 6px;">
    <table class="table-custom table-bordered text-center align-middle" style="font-size: 10pt; width: 100%;">
      <thead>
        <tr>
          <th style="width: 4%; padding: 2pt 2pt;">#</th>
          <th style="width: 26%; padding: 2pt 2pt;">الصنف</th>
          <th style="width: 10%; padding: 2pt 2pt;">التعبئة</th>
          <th style="width: 10%; padding: 2pt 2pt;">حجم العبوة</th>
          <th style="width: 10%; padding: 2pt 2pt;">شد الكرتون</th>
          <% if (isFullMode) { %>
          <th style="width: 12%; padding: 2pt 2pt;">كلفة الطرد</th>
          <th style="width: 8%; padding: 2pt 2pt;">نسبة الربح</th>
          <% } %>
          <th style="width: 12%; padding: 2pt 2pt;">السعر</th>
          <th style="width: 8%; padding: 2pt 2pt;">الكمية</th>
          <th style="width: 14%; padding: 2pt 2pt;">المجموع</th>
          <th style="width: 6%; padding: 2pt 2pt;">ملاحظات</th>
        </tr>
      </thead>
      <tbody>
        <% const rowsPerPage = 36; const rowsOnFirstPage = 21; %>
        <%
          const groupedQuotationPrintMap = new Map();
          (items || []).forEach((it) => {
            const key = (it.material_name || '').trim();
            if (!groupedQuotationPrintMap.has(key)) groupedQuotationPrintMap.set(key, []);
            groupedQuotationPrintMap.get(key).push(it);
          });
          const groupedQuotationPrintRows = [];
          let rowNo = 1;
          Array.from(groupedQuotationPrintMap.values()).forEach((group) => {
            group.forEach((it, idxInGroup) => {
              groupedQuotationPrintRows.push({
                item: it,
                rowNumber: rowNo++,
                isFirstInGroup: idxInGroup === 0,
                groupLength: group.length
              });
            });
          });
        %>
        <% groupedQuotationPrintRows.forEach((row, idx) => { const item = row.item; %>
          <% if (idx === rowsOnFirstPage || (idx > rowsOnFirstPage && ((idx - rowsOnFirstPage) % rowsPerPage) === 0)) { %>
            <tr class="page-break"><td colspan="<%= quotationTableColumnCount %>"></td></tr>
          <% } %>
          <tr>
            <td style="padding: 2pt 2pt;"><%= row.rowNumber %></td>
            <% if (row.isFirstInGroup) { %>
            <td style="padding: 2pt 2pt; text-align: right; line-height: 1.15;" rowspan="<%= row.groupLength %>">
              <div><%= item.material_name || '-' %></div>
            </td>
            <% } %>
            <td style="padding: 2pt 2pt;"><%= item.packaging_unit || '-' %></td>
            <td style="padding: 2pt 2pt;"><%= item.packaging_weight != null ? formatNumberDisplay(item.packaging_weight) : '-' %></td>
            <td style="padding: 2pt 2pt;"><%= item.pieces_per_package != null ? formatNumberDisplay(item.pieces_per_package) : '-' %></td>
            <% if (isFullMode) { %>
            <td style="padding: 2pt 2pt;"><span class="money-inline"><%= `${formatNumberDisplay(item.unit_cost)} ${currencySymbol}` %></span></td>
            <td style="padding: 2pt 2pt;"><%= `${formatNumberDisplay(item.profit_percentage || 0)}%` %></td>
            <% } %>
            <td style="padding: 2pt 2pt;"><span class="money-inline"><%= `${formatNumberDisplay(item.final_price)} ${currencySymbol}` %></span></td>
            <td style="padding: 2pt 2pt;"><%= item.quantity != null ? formatNumberDisplay(item.quantity) : '-' %></td>
            <td style="padding: 2pt 2pt;"><span class="money-inline"><%= `${formatNumberDisplay(item.total_price)} ${currencySymbol}` %></span></td>
            <td style="padding: 2pt 2pt;"><%= item.item_notes || '-' %></td>
          </tr>
        <% }) %>
        <% if ((groupedQuotationPrintRows||[]).length <= rowsOnFirstPage) { %>
          <tr class="total-row">
            <td colspan="<%= quotationTotalLabelColspan %>" style="text-align: center; font-weight: 700;">الإجمالي</td>
            <td style="font-weight:700;"><span class="money-inline"><%= `${formatTotalDisplay(totalBeforeDiscount)} ${currencySymbol}` %></span></td>
            <td></td>
          </tr>
          <% if (hasDiscount) { %>
          <tr class="total-row">
            <td colspan="<%= quotationTotalLabelColspan %>" style="text-align: center; font-weight: 700;">الخصم</td>
            <td style="font-weight:700;"><span class="money-inline"><%= `- ${formatDiscountDisplay(discountValue)} ${currencySymbol}` %></span></td>
            <td></td>
          </tr>
          <tr class="total-row">
            <td colspan="<%= quotationTotalLabelColspan %>" style="text-align: center; font-weight: 700;">الإجمالي بعد الخصم</td>
            <td style="font-weight:700;"><span class="money-inline"><%= `${formatDiscountDisplay(totalAfterDiscount)} ${currencySymbol}` %></span></td>
            <td></td>
          </tr>
          <% } %>
        <% } else { %>
          <% const remainder = ((groupedQuotationPrintRows||[]).length - rowsOnFirstPage) % rowsPerPage; %>
          <% const isExactMultiple = remainder === 0; %>
          <% if (isExactMultiple) { %>
            <tr class="page-break"><td colspan="<%= quotationTableColumnCount %>"></td></tr>
          <% } %>
          <tr class="total-row">
            <td colspan="<%= quotationTotalLabelColspan %>" style="text-align: center; font-weight: 700;">الإجمالي</td>
            <td style="font-weight:700;"><span class="money-inline"><%= `${formatTotalDisplay(totalBeforeDiscount)} ${currencySymbol}` %></span></td>
            <td></td>
          </tr>
          <% if (hasDiscount) { %>
          <tr class="total-row">
            <td colspan="<%= quotationTotalLabelColspan %>" style="text-align: center; font-weight: 700;">الخصم</td>
            <td style="font-weight:700;"><span class="money-inline"><%= `- ${formatDiscountDisplay(discountValue)} ${currencySymbol}` %></span></td>
            <td></td>
          </tr>
          <tr class="total-row">
            <td colspan="<%= quotationTotalLabelColspan %>" style="text-align: center; font-weight: 700;">الإجمالي بعد الخصم</td>
            <td style="font-weight:700;"><span class="money-inline"><%= `${formatDiscountDisplay(totalAfterDiscount)} ${currencySymbol}` %></span></td>
            <td></td>
          </tr>
          <% } %>
        <% } %>
      </tbody>
      
    </table>
  </div>

  <!-- Footer -->
  <div class="print-footer" id="fixed-print-footer" style="text-align:center; font-size: 8.5pt; margin-top: 6px;">
    <hr style="margin: 4px 0; border: 0.5px solid #bbb;">
    سوريا، حماة، أوتستراد دمشق-حلب الدولي، س.ت 10369 – س.ص 10<br>
    0940500511 – 0988111127 | ajajbrothers@gmail.com<br>
    جميع الحقوق محفوظة © <%= new Date().getFullYear() %> نظام إدارة المختبر | تم التطوير بواسطة شركة NEXA GROUP
  </div>
</div>

<script>
  window.addEventListener('load', function(){ setTimeout(function(){ window.print(); }, 200); });
  function closeAfterPrint(){ setTimeout(function(){ try{ window.close(); }catch(e){} }, 100); }
  if ('onafterprint' in window) { window.addEventListener('afterprint', closeAfterPrint); }
  var mql = window.matchMedia && window.matchMedia('print');
  if (mql) {
    if (mql.addEventListener) { mql.addEventListener('change', function(e){ if(!e.matches) closeAfterPrint(); }); }
    else if (mql.addListener) { mql.addListener(function(e){ if(!e.matches) closeAfterPrint(); }); }
  }
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Amiri:wght@400;500;600;700&display=swap');
  @page { size: A4 portrait; margin: 1cm 1cm 0.8cm 1cm; }
  html, body { background: #fff !important; margin:0; padding:0; direction: rtl; text-align: right; font-family: 'Cairo','Amiri','Noto Naskh Arabic',sans-serif !important; font-size: 9.5pt; }
  .table-custom { width: 100%; border-collapse: separate; border-spacing: 0; }
  .table-custom th, .table-custom td { border: 0.7px solid #444; }
  .table-custom th { background: #f5f5f5; font-weight: 700; }
  thead { display: table-header-group; }
  tfoot { display: none; }
  tr { page-break-inside: avoid; }
  .table-responsive { overflow-x: visible; }
  .info-grid { display: grid; grid-template-columns: 1fr; gap: 4pt; }
  .box-compact { border: 1px solid #ccc; padding: 4pt; border-radius: 3px; }
  .section-title { font-size: 9pt; font-weight: 700; margin: 0 0 2pt 0; }
  .grid-kv { display: grid; grid-template-columns: 1fr 1fr; gap: 2pt 6pt; }
  .kv { display: grid; grid-template-columns: auto 1fr; column-gap: 6pt; border-bottom: 1px dashed #e0e0e0; padding: 1pt 0; align-items: start; }
  .kv.full { grid-column: 1 / -1; }
  .kv span:first-child { color: #333; font-weight: 600; margin-left: 6px; }
  .kv span:last-child { white-space: normal; word-break: break-word; }
  .notes { white-space: pre-wrap; line-height: 1.3; font-size: 9pt; }
  .money-inline { white-space: nowrap; display: inline-block; }
  .container-fluid { padding-bottom: 120px; }
  .print-footer { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; }
  .table-custom th, .table-custom td { padding: 3pt 2pt; line-height: 1.3; }
  .page-break { page-break-before: always; break-before: page; height: 0; }
  .table-custom tr.page-break td { border: 0; padding: 0; height: 0; }
  .total-row td { background: #f5f5f5; }
</style>
