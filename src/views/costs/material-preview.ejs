<%- include('../layouts/header') %>
<%
const __isSyp = (typeof defaultCurrency !== 'undefined' && defaultCurrency && defaultCurrency.code === 'SYP');
const __exchangeRate = (typeof exchangeRate !== 'undefined' && exchangeRate) ? parseFloat(exchangeRate) : 13000;
const __currencySymbol = (typeof defaultCurrency !== 'undefined' && defaultCurrency && defaultCurrency.symbol) ? defaultCurrency.symbol : '$';
function formatNumberDisplay(value) {
  if (value === null || value === undefined || value === '') return '-';
  if (typeof value === 'string' && /^-?\d+(\.\d+)?$/.test(value.trim())) return value.trim();
  const num = parseFloat(value);
  if (isNaN(num)) return '-';
  if (Number.isInteger(num)) return String(num);
  return num.toString();
}
function formatTotalDisplay(value) {
  const num = parseFloat(value);
  if (!Number.isFinite(num)) return '0';
  const normalized = Number.isInteger(num)
    ? String(num)
    : num.toFixed(6).replace(/0+$/,'').replace(/\.$/,'');
  const neg = normalized.startsWith('-');
  const clean = neg ? normalized.slice(1) : normalized;
  const [intPart, fracPart] = clean.split('.');
  const grouped = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  const out = grouped + (fracPart ? `.${fracPart}` : '');
  return neg ? ('\u200E-' + out) : out;
}
let __additionalExpenseItems = [];
try {
  if (typeof material.additional_expense_items === 'string') __additionalExpenseItems = JSON.parse(material.additional_expense_items || '[]');
  else __additionalExpenseItems = material.additional_expense_items || [];
} catch (_) {
  __additionalExpenseItems = [];
}
if (!Array.isArray(__additionalExpenseItems)) __additionalExpenseItems = [];
const __isExternalMaterial = material.material_origin === 'external';
%>

<div class="container mt-4 no-auto-num-center">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-eye"></i> معاينة المادة</h2>
                <div>
                    <a href="/costs/cost-statement/<%= material.id %>/print" target="_blank" class="btn btn-primary me-2">
                        <i class="bi bi-printer me-1"></i> طباعة
                    </a>
                    <button id="exportMaterialPdfBtn" class="btn btn-success me-2">
                        <i class="bi bi-file-earmark-pdf"></i> تصدير PDF
                    </button>
                    <a href="/costs/cost-statement" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-right me-1"></i> العودة لبيان الكلفة
                    </a>
                </div>
            </div>

            <!-- تفاصيل المادة -->
            <div class="card shadow mb-4">
                <!-- PDF Export Modal -->
                <div id="materialPdfExportModal" class="modal fade" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-file-earmark-pdf me-2 text-success"></i> تم إنشاء ملف PDF</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                            </div>
                            <div class="modal-body text-center">
                                <div class="mb-3">
                                    <input type="text" id="materialPdfLinkInput" class="form-control text-center" readonly style="direction:ltr; font-size:0.95em;" />
                                </div>
                                <div class="d-flex justify-content-center gap-2 mb-2">
                                    <button id="copyMaterialPdfLinkBtn" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard me-1"></i> نسخ الرابط</button>
                                    <a id="openMaterialPdfLinkBtn" class="btn btn-outline-info btn-sm" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i> فتح الرابط</a>
                                    <a id="whatsappMaterialShareBtn" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-whatsapp me-1"></i> ارسال عبر واتساب</a>
                                </div>
                                <div class="alert alert-success py-2 mb-0">يمكنك مشاركة الرابط مع أي شخص لتحميل تفاصيل المادة مباشرة</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> تفاصيل المادة</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">المعلومات الأساسية</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>اسم المادة:</strong></td>
                                    <td><%= material.material_name %></td>
                                </tr>
                                <tr>
                                    <td><strong>نوع المادة:</strong></td>
                                    <td><%= material.material_type %></td>
                                </tr>
                                <tr>
                                    <td><strong>تاريخ الإضافة:</strong></td>
                                    <td><%= formatDate(material.created_at) %></td>
                                </tr>
                                <tr>
                                    <td><strong>آخر تحديث:</strong></td>
                                    <td><%= formatDate(material.updated_at) %></td>
                                </tr>
                                <tr>
                                    <td><strong>طريقة الحساب:</strong></td>
                                    <td>
                                        <span class="badge <%= material.calculation_method === 'components' ? 'bg-info' : 'bg-secondary' %>">
                                            <%= material.calculation_method === 'components' ? 'العناصر الفرعية' : 'التقليدية' %>
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">نتائج الحساب</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>كلفة القطعة الواحدة:</strong></td>
                            <td class="text-primary fw-bold">
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.unit_cost) || 0))
                                    : formatNumberDisplay(material.unit_cost)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>كلفة الطرد:</strong></td>
                            <td class="text-success fw-bold">
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.package_cost) || 0))
                                    : formatNumberDisplay(material.package_cost)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <% if (__isExternalMaterial) { %>
                    <hr>
                    <div class="row">
                        <div class="col-md-8">
                            <h6 class="text-primary mb-3">بيانات المادة الخارجية</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>وحدة التعبئة:</strong></td>
                                    <td><%= material.packaging_unit || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>كلفة القطعة:</strong></td>
                                    <td>
                                        <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                            ? String(Math.round(parseFloat(material.unit_cost) || 0))
                                            : formatNumberDisplay(material.unit_cost)
                                        %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>كلفة الطرد:</strong></td>
                                    <td>
                                        <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                            ? String(Math.round(parseFloat(material.package_cost) || 0))
                                            : formatNumberDisplay(material.package_cost)
                                        %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>الوزن الصافي:</strong></td>
                                    <td><%= formatNumberDisplay(material.packaging_weight) %> كجم</td>
                                </tr>
                                <tr>
                                    <td><strong>كلفة الكيلو:</strong></td>
                                    <td>
                                        <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                            ? String(Math.round(parseFloat(material.price_before_waste) || 0))
                                            : formatNumberDisplay(material.price_before_waste)
                                        %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>ملاحظات:</strong></td>
                                    <td><%= material.external_notes || '-' %></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <% } else { %>
                    <!-- العناصر الفرعية -->
                    <% if (material.calculation_method === 'components' && components && components.length > 0) { %>
                    <hr>
                    <div class="row">
                        <div class="col-12">
                            <h6 class="text-primary mb-3"><i class="bi bi-puzzle"></i> العناصر الفرعية للمادة</h6>
                            <div class="table-responsive">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 40%;">اسم العنصر</th>
                                            <th style="width: 20%;">الوزن (غرام)</th>
                                            <th style="width: 25%;">سعر الكيلو</th>
                                            <th style="width: 15%;">التكلفة</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% let totalWeight = 0, totalCost = 0; %>
                                        <% components.forEach(component => { %>
                                            <%
                                                const weightRaw = component.weight_grams;
                                                const weight = parseFloat(weightRaw) || 0;
                                                const priceRaw = (defaultCurrency && defaultCurrency.code === 'SYP')
                                                    ? (component.price_per_kg_syp || component.price_per_kg || 0)
                                                    : (component.price_per_kg || 0);
                                                const price = parseFloat(priceRaw) || 0;
                                                const cost = (weight / 1000) * price;
                                                totalWeight += weight;
                                                totalCost += cost;
                                            %>
                                            <tr>
                                                <td><%= component.component_name %></td>
                                                <td><%= formatNumberDisplay(weightRaw) %> غ</td>
                                                <td>
                                                    <%= formatNumberDisplay(priceRaw) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                                </td>
                                                <td>
                                                    <%= formatNumberDisplay(cost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                    <tfoot class="table-info">
                                        <tr>
                                            <th>المجموع</th>
                                            <th><%= formatTotalDisplay(totalWeight) %> غ</th>
                                            <th>
                                                متوسط: <%= totalWeight > 0 ? formatTotalDisplay(totalCost / (totalWeight / 1000)) : '0' %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                            </th>
                                            <th>
                                                <%= formatTotalDisplay(totalCost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                            </th>
                                        </tr>
                                        <tr class="table-success">
                                            <th colspan="2">الوزن الإجمالي: <%= formatTotalDisplay(totalWeight / 1000) %> كجم</th>
                                            <th colspan="2">السعر الإجمالي: 
                                                <%= formatTotalDisplay(totalCost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                            </th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">بيانات التكلفة الأساسية</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>السعر قبل الهدر (إجمالي):</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.price_before_waste) || 0))
                                    : formatNumberDisplay(material.price_before_waste)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>الوزن الجمالي:</strong></td>
                                    <td><%= formatNumberDisplay(material.gross_weight) %> كجم</td>
                                </tr>
                                <tr>
                                    <td><strong>نسبة الهدر:</strong></td>
                                    <td><%= formatNumberDisplay(material.waste_percentage) %>%</td>
                                </tr>
                                <tr>
                                    <td><strong>الوزن الصافي:</strong></td>
                                    <td><%= (parseFloat(material.gross_weight) * (1 - parseFloat(material.waste_percentage) / 100)).toFixed(2) %> كجم</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">بيانات التعبئة</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>وحدة التعبئة:</strong></td>
                                    <td><%= material.packaging_unit %></td>
                                </tr>
                                <tr>
                                    <td><strong>وزن المادة (داخل العبوة):</strong></td>
                                    <td><%= (material.packaging_weight != null) ? formatNumberDisplay(material.packaging_weight) : '-' %> كجم</td>
                                </tr>
                                <tr>
                                    <td><strong>وزن العبوة الفارغة:</strong></td>
                                    <td><%= (material.packaging_unit_weight != null) ? formatNumberDisplay(material.packaging_unit_weight) : '-' %> كجم</td>
                                </tr>
                                <tr>
                                    <td><strong>وزن الطرد القائم:</strong></td>
                                    <td><%= (material.gross_package_weight != null) ? formatNumberDisplay(material.gross_package_weight) : '-' %> كجم</td>
                                </tr>
                                <tr>
                                    <td><strong>عدد الحبات في الطرد:</strong></td>
                                    <td><%= material.pieces_per_package %></td>
                                </tr>
                                <tr>
                                    <td><strong>عدد الطرود في الطبلية:</strong></td>
                                    <td><%= material.packages_per_pallet %></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">تكاليف التعبئة</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>ثمن العبوة الفارغة:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.empty_package_price) || 0))
                                    : formatNumberDisplay(material.empty_package_price)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>ثمن اللصاقة:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.sticker_price) || 0))
                                    : formatNumberDisplay(material.sticker_price)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>ثمن كرتونة:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.carton_price) || 0))
                                    : formatNumberDisplay(material.carton_price)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>ثمن الطبلية:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.pallet_price) || 0))
                                    : formatNumberDisplay(material.pallet_price)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">تكاليف إضافية</h6>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>مصاريف إضافية:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.additional_expenses) || 0))
                                    : formatNumberDisplay(material.additional_expenses)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>تفصيل المصاريف الإضافية:</strong></td>
                                    <td>
                                        <% if (__additionalExpenseItems.length) { %>
                                            <% __additionalExpenseItems.forEach(function(item, idx){ 
                                                const usdVal = parseFloat(item.price) || 0;
                                                const shownVal = __isSyp ? (usdVal * __exchangeRate) : usdVal;
                                                const shownText = __isSyp ? formatNumberDisplay(shownVal) : formatNumberDisplay(item.price);
                                            %>
                                                <div><%= item.name || 'بدون اسم' %>: <%= shownText %> <%= __currencySymbol %></div>
                                            <% }); %>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>مصروف عمال:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.labor_cost) || 0))
                                    : formatNumberDisplay(material.labor_cost)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                                <tr>
                                    <td><strong>مواد حافظة:</strong></td>
                            <td>
                                <%= (defaultCurrency && defaultCurrency.code === 'SYP')
                                    ? String(Math.round(parseFloat(material.preservatives_cost) || 0))
                                    : formatNumberDisplay(material.preservatives_cost)
                                %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                            </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <h6 class="text-primary mb-3">أوزان إضافية</h6>
                            <% 
                              let extras = [];
                              try {
                                if (typeof material.extra_weights === 'string') { extras = JSON.parse(material.extra_weights || '[]'); }
                                else { extras = material.extra_weights || []; }
                              } catch (e) { extras = []; }
                              const extrasTotal = (extras || []).reduce((s, ew) => s + (parseFloat(ew.weight) || 0), 0);
                            %>
                            <% if (extras && extras.length > 0) { %>
                              <div class="table-responsive">
                                <table class="table table-bordered">
                                  <thead class="table-light">
                                    <tr>
                                      <th>اسم المادة الإضافية</th>
                                      <th>الوزن (كجم)</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% extras.forEach(function(ew){ %>
                                      <tr>
                                        <td><%= ew.name || '-' %></td>
                                        <td><%= formatNumberDisplay(ew.weight) %></td>
                                      </tr>
                                    <% }) %>
                                  </tbody>
                                  <tfoot>
                                    <tr>
                                      <th class="text-end">المجموع</th>
                                      <th><%= formatTotalDisplay(extrasTotal) %></th>
                                    </tr>
                                  </tfoot>
                                </table>
                              </div>
                            <% } else { %>
                              <div class="text-muted">لا توجد أوزان إضافية</div>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- سجل التكاليف -->
            <% if (!__isExternalMaterial) { %>
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-clock-history"></i> سجل التكاليف</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped" id="costLogsTable">
                            <thead>
                                <tr>
                                    <th>التاريخ</th>
                                    <th>كلفة القطعة</th>
                                    <th>كلفة الطرد</th>
                                </tr>
                            </thead>
                            <tbody id="costLogsBody">
                                <!-- سيتم ملؤها بالبيانات -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <% } %>


        </div>
    </div>
</div>

<script>
// دالة تنسيق التاريخ
function formatDate(dateString) {
    if (!dateString) return '-';
    const date = new Date(dateString);
    const day = date.getDate().toString().padStart(2, '0');
    const month = (date.getMonth() + 1).toString().padStart(2, '0');
    const year = date.getFullYear();
    return `${day}/${month}/${year}`;
}

            // دالة جلب سجل التكاليف
            const currencySymbol = '<%= defaultCurrency ? defaultCurrency.symbol : "$" %>';
function loadCostLogs() {
    const formatInlineNumber = (value) => {
        if (value === null || value === undefined || value === '') return '-';
        if (typeof value === 'string' && /^-?\d+(\.\d+)?$/.test(value.trim())) return value.trim();
        const num = Number(value);
        if (!Number.isFinite(num)) return '-';
        return String(num);
    };
    fetch(`/costs/cost-statement/<%= material.id %>/logs`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const tbody = document.getElementById('costLogsBody');
                tbody.innerHTML = '';
                
                data.logs.forEach(log => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td>${formatDate(log.calculation_date)}</td>
                                <td>${formatInlineNumber(log.unit_cost)} ${currencySymbol}</td>
                                <td>${formatInlineNumber(log.package_cost)} ${currencySymbol}</td>
                    `;
                    tbody.appendChild(row);
                });
            }
        })
        .catch(error => {
            console.error('خطأ في جلب سجل التكاليف:', error);
        });
}

// دالة طباعة تفاصيل المادة
function printMaterialDetails() {
    const printWindow = window.open('', '_blank');
    const materialName = '<%= material.material_name %>';
    
    printWindow.document.write(`
        <html dir="rtl">
        <head>
            <title>معاينة المادة - ${materialName}</title>
            <style>
                body { font-family: Arial, sans-serif; margin: 20px; }
                .header { text-align: center; margin-bottom: 30px; }
                .section { margin-bottom: 20px; }
                .section h3 { color: #007bff; border-bottom: 2px solid #007bff; padding-bottom: 5px; }
                table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
                th, td { border: 1px solid #ddd; padding: 8px; text-align: right; }
                th { background-color: #f8f9fa; }
                .highlight { background-color: #e3f2fd; font-weight: bold; }
                @media print { .no-print { display: none; } }
            </style>
        </head>
        <body>
            <div class="header">
                <h1>معاينة المادة</h1>
                <h2>${materialName}</h2>
            </div>
            
            <div class="section">
                <h3>المعلومات الأساسية</h3>
                <table>
                    <tr><th>اسم المادة</th><td>${materialName}</td></tr>
                    <tr><th>نوع المادة</th><td><%= material.material_type %></td></tr>
                    <tr><th>تاريخ الإضافة</th><td><%= formatDate(material.created_at) %></td></tr>
                    <tr><th>آخر تحديث</th><td><%= formatDate(material.updated_at) %></td></tr>
                </table>
            </div>
            
            <div class="section">
                <h3>نتائج الحساب</h3>
                <table>
                                    <tr class="highlight"><th>كلفة القطعة الواحدة</th><td><%= formatNumberDisplay(material.unit_cost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                <tr class="highlight"><th>كلفة الطرد</th><td><%= formatNumberDisplay(material.package_cost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                </table>
            </div>
            
            <div class="section">
                <h3>بيانات التكلفة الأساسية</h3>
                <table>
                    <tr><th>السعر قبل الهدر</th><td><%= formatNumberDisplay(material.price_before_waste) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>/كجم</td></tr>
                    <tr><th>الوزن الجمالي</th><td><%= formatNumberDisplay(material.gross_weight) %> كجم</td></tr>
                    <tr><th>نسبة الهدر</th><td><%= formatNumberDisplay(material.waste_percentage) %>%</td></tr>
                    <tr><th>الوزن الصافي</th><td><%= (parseFloat(material.gross_weight) * (1 - parseFloat(material.waste_percentage) / 100)).toFixed(2) %> كجم</td></tr>
                </table>
            </div>
            
            <div class="section">
                <h3>بيانات التعبئة</h3>
                <table>
                    <tr><th>وحدة التعبئة</th><td><%= material.packaging_unit %></td></tr>
                    <tr><th>وزن وحدة التعبئة</th><td><%= formatNumberDisplay(material.packaging_weight) %> كجم</td></tr>
                    <tr><th>عدد الحبات في الطرد</th><td><%= material.pieces_per_package %></td></tr>
                    <tr><th>عدد الطرود في الطبلية</th><td><%= material.packages_per_pallet %></td></tr>
                </table>
            </div>
            
            <div class="section">
                <h3>تكاليف التعبئة</h3>
                <table>
                                    <tr><th>ثمن العبوة الفارغة</th><td><%= formatNumberDisplay(material.empty_package_price) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                <tr><th>ثمن اللصاقة</th><td><%= formatNumberDisplay(material.sticker_price) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                <tr><th>ثمن كرتونة</th><td><%= formatNumberDisplay(material.carton_price) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                <tr><th>ثمن الطبلية</th><td><%= formatNumberDisplay(material.pallet_price) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                </table>
            </div>
            
            <div class="section">
                <h3>تكاليف إضافية</h3>
                <table>
                                    <tr><th>مصاريف إضافية</th><td><%= formatNumberDisplay(material.additional_expenses) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                <tr><th>تفصيل المصاريف الإضافية</th><td>
                    <% if (__additionalExpenseItems.length) { %>
                        <% __additionalExpenseItems.forEach(function(item){ 
                            const usdVal = parseFloat(item.price) || 0;
                            const shownVal = __isSyp ? (usdVal * __exchangeRate) : usdVal;
                            const shownText = __isSyp ? formatNumberDisplay(shownVal) : formatNumberDisplay(item.price);
                        %>
                            <div><%= item.name || 'بدون اسم' %>: <%= shownText %> <%= __currencySymbol %></div>
                        <% }); %>
                    <% } else { %>
                        -
                    <% } %>
                </td></tr>
                <tr><th>مصروف عمال</th><td><%= formatNumberDisplay(material.labor_cost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                <tr><th>مواد حافظة</th><td><%= formatNumberDisplay(material.preservatives_cost) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></td></tr>
                </table>
            </div>
        </body>
        </html>
    `);
    
    printWindow.document.close();
    printWindow.print();
}

// دالة حذف المادة
function deleteMaterial(materialId) {
    if (confirm('هل أنت متأكد من حذف هذه المادة؟')) {
        fetch(`/costs/cost-statement/${materialId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showAlert('تم حذف المادة بنجاح', 'success');
                setTimeout(() => {
                    window.location.href = '/costs/cost-statement';
                }, 1500);
            } else {
                showAlert(data.message || 'حدث خطأ في حذف المادة', 'error');
            }
        })
        .catch(error => {
            showAlert('حدث خطأ في حذف المادة', 'error');
        });
    }
}

// دالة عرض التنبيهات
function showAlert(message, type) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
    alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(alertDiv);
    
    setTimeout(() => {
        alertDiv.remove();
    }, 5000);
}

// تحميل سجل التكاليف عند تحميل الصفحة
document.addEventListener('DOMContentLoaded', function() {
    loadCostLogs();
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function(){
  const exportBtn = document.getElementById('exportMaterialPdfBtn');
  const modalElem = document.getElementById('materialPdfExportModal');
  const modal = modalElem ? new bootstrap.Modal(modalElem) : null;
  const linkInput = document.getElementById('materialPdfLinkInput');
  const copyBtn = document.getElementById('copyMaterialPdfLinkBtn');
  const openBtn = document.getElementById('openMaterialPdfLinkBtn');
  const waBtn = document.getElementById('whatsappMaterialShareBtn');
  if (exportBtn) {
    exportBtn.addEventListener('click', async function(){
      exportBtn.disabled = true;
      exportBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> جاري التصدير...';
      try {
        const res = await fetch(`/costs/cost-statement/<%= material.id %>/pdf`);
        const data = await res.json();
        if (data.success && data.url) {
          if (linkInput) linkInput.value = data.url;
          if (openBtn) openBtn.href = data.url;
          if (waBtn) waBtn.href = `https://wa.me/?text=${encodeURIComponent(data.url)}`;
          if (modal) modal.show();
        } else {
          alert(data.message || 'حدث خطأ أثناء توليد ملف PDF');
        }
      } catch (e) {
        alert('حدث خطأ في الاتصال بالخادم');
      }
      exportBtn.disabled = false;
      exportBtn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> تصدير PDF';
    });
  }
  if (copyBtn && linkInput) {
    copyBtn.addEventListener('click', function(){ linkInput.select(); document.execCommand('copy'); });
  }
});
</script>
