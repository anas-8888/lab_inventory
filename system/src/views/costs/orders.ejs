<%
  const pageCurrency =
    (typeof currency !== 'undefined' && currency) ||
    (typeof defaultCurrency !== 'undefined' && defaultCurrency) ||
    null;
%>
<div
    id="ordersPageData"
    data-currency-symbol="<%= (pageCurrency && pageCurrency.symbol) ? pageCurrency.symbol : '$' %>"
    data-exchange-rate="<%= (pageCurrency && pageCurrency.code === 'SYP') ? (pageCurrency.exchangeRate || 1) : 1 %>"
    data-currency-code="<%= (pageCurrency && pageCurrency.code) ? pageCurrency.code : 'USD' %>"
    hidden
></div>
<script id="ordersMaterialsJson" type="application/json"><%- JSON.stringify(materials || []) %></script>

<script>
// تعليق
(() => {
  const materialsJsonEl = document.getElementById('ordersMaterialsJson');
  try {
    window.materials = JSON.parse(materialsJsonEl?.textContent || "[]");
  } catch (_) {
    window.materials = [];
  }
})();
const groupedMaterials = (() => {
  const source = Array.isArray(window.materials) ? window.materials : [];
  const byName = new Map();
  source.forEach((m) => {
    const key = (m && m.material_name ? String(m.material_name) : '').trim();
    if (!key) return;
    if (!byName.has(key)) byName.set(key, m);
  });
  return Array.from(byName.values());
})();
const pageDataEl = document.getElementById('ordersPageData');
const currencySymbol = pageDataEl?.dataset?.currencySymbol || '';
const exchangeRate = parseFloat(pageDataEl?.dataset?.exchangeRate || '1') || 1;
const defaultCurrencyCode = pageDataEl?.dataset?.currencyCode || '';
const isSyp = defaultCurrencyCode === 'SYP';

// تعليق
(() => {
  const editModal = document.getElementById('editOrderModal');
  if (!editModal) return;
  editModal.querySelectorAll('input[inputmode="decimal"]').forEach((input) => {
    input.setAttribute('type', 'text');
    input.setAttribute('inputmode', 'decimal');
  });
})();

// تعليق
const formatUSD = (v) => {
  const n = parseFloat(v);
  if (!Number.isFinite(n)) return '0';
  return String(n);
};
const formatSYP = (v) => String(Math.round(parseFloat(v) || 0));
const displayMoney = (v) => {
  const value = parseFloat(v) || 0;
  return defaultCurrencyCode === 'SYP' ? formatSYP(value) : formatUSD(value);
};

// تعليق
const roundToDecimal = (value, decimals = 2) => {
  return Math.round(value * Math.pow(10, decimals)) / Math.pow(10, decimals);
};
let nextOrderRowId = 0;
let currentDateInput = null;
let selectedDate = null;
let currentMonth = new Date().getMonth();
let currentYear = new Date().getFullYear();
let currentOrderPickerRowId = null;

// تعليق
const monthNames = [
    'يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو',
    'يوليو', 'أغسطس', 'سبتمبر', 'أكتوبر', 'نوفمبر', 'ديسمبر'
];

// تعليق
const dayNames = ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];

// تعليق
document.addEventListener('DOMContentLoaded', function() {
    initializeCalendar();
    setDefaultDates();
    
    // تعليق
    const modals = document.querySelectorAll('.modal');
    modals.forEach(modal => {
        // تعليق
        modal.removeAttribute('aria-hidden');
        
        modal.addEventListener('shown.bs.modal', function() {
            // تعليق
            setTimeout(() => {
                const firstFocusable = this.querySelector('input:not([readonly]), button:not([disabled]), select, textarea');
                if (firstFocusable) {
                    firstFocusable.focus();
                }
            }, 100);
        });
        
        // تعليق
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.type === 'attributes' && mutation.attributeName === 'aria-hidden') {
                    modal.removeAttribute('aria-hidden');
                }
            });
        });
        
        observer.observe(modal, {
            attributes: true,
            attributeFilter: ['aria-hidden']
        });
    });
    
    // تعليق
    document.getElementById('prevMonth').addEventListener('click', function() {
        currentMonth--;
        if (currentMonth < 0) {
            currentMonth = 11;
            currentYear--;
        }
        renderCalendar();
    });
    
    document.getElementById('nextMonth').addEventListener('click', function() {
        currentMonth++;
        if (currentMonth > 11) {
            currentMonth = 0;
            currentYear++;
        }
        renderCalendar();
    });
    
    document.getElementById('monthSelect').addEventListener('change', function() {
        currentMonth = parseInt(this.value) - 1;
        renderCalendar();
    });
    
    document.getElementById('yearSelect').addEventListener('change', function() {
        currentYear = parseInt(this.value);
        renderCalendar();
    });
    
    document.getElementById('confirmDate').addEventListener('click', function() {
        if (selectedDate) {
            const day = selectedDate.getDate().toString().padStart(2, '0');
            const month = (selectedDate.getMonth() + 1).toString().padStart(2, '0');
            const year = selectedDate.getFullYear();
            const formattedDate = `${day}/${month}/${year}`;
            
            if (currentDateInput) currentDateInput.value = formattedDate;
            
            const modal = bootstrap.Modal.getInstance(document.getElementById('datePickerModal'));
            modal.hide();
        }
    });
});

// تعليق
function initializeCalendar() {
    // تعليق
    const yearSelect = document.getElementById('yearSelect');
    const currentYear = new Date().getFullYear();
    
    for (let year = currentYear - 10; year <= currentYear + 5; year++) {
        const option = document.createElement('option');
        option.value = year;
        option.textContent = year;
        yearSelect.appendChild(option);
    }
    
    // تعليق
    document.getElementById('monthSelect').value = currentMonth + 1;
    document.getElementById('yearSelect').value = currentYear;
    
    renderCalendar();
}

// تعليق
function renderCalendar() {
    const calendarBody = document.getElementById('calendarBody');
    const currentMonthYear = document.getElementById('currentMonthYear');
    
    // تعليق
    currentMonthYear.textContent = `${monthNames[currentMonth]} ${currentYear}`;
    
    // تعليق
    document.getElementById('monthSelect').value = currentMonth + 1;
    document.getElementById('yearSelect').value = currentYear;
    
    // تعليق
    const firstDay = new Date(currentYear, currentMonth, 1);
    const lastDay = new Date(currentYear, currentMonth + 1, 0);
    const startDate = new Date(firstDay);
    startDate.setDate(startDate.getDate() - firstDay.getDay());
    
    let calendarHTML = '<div class="calendar-grid">';
    
    // تعليق
    dayNames.forEach(day => {
        calendarHTML += `<div class="calendar-day-header">${day}</div>`;
    });
    
    // تعليق
    for (let i = 0; i < 42; i++) {
        const date = new Date(startDate);
        date.setDate(startDate.getDate() + i);
        
        const isCurrentMonth = date.getMonth() === currentMonth;
        const isToday = date.toDateString() === new Date().toDateString();
        const isSelected = selectedDate && date.toDateString() === selectedDate.toDateString();
        
        let className = 'calendar-day';
        if (!isCurrentMonth) className += ' other-month';
        if (isToday) className += ' today';
        if (isSelected) className += ' selected';
        
        calendarHTML += `<div class="${className}" onclick="selectDate(new Date(${date.getTime()}))">${date.getDate()}</div>`;
    }
    
    calendarHTML += '</div>';
    calendarBody.innerHTML = calendarHTML;
}

// تعليق
function selectDate(date) {
    selectedDate = date;
    renderCalendar();
}

