<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-file-earmark-text"></i> عرض سعر <%= quotation.quotation_number %></h2>
                <div>
                    <button id="printQuotationBtn" class="btn btn-outline-primary me-2" type="button">
                        <i class="bi bi-printer"></i> طباعة
                    </button>
                    <button id="exportQuotationPdfBtn" class="btn btn-success me-2">
                        <i class="bi bi-file-earmark-pdf"></i> تصدير PDF
                    </button>
                    <a href="/costs/quotations" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-right me-1"></i> العودة للعروض
                    </a>
                </div>
            </div>

            <!-- حساب الإجمالي النهائي -->
            <% 
                const isSYP = (defaultCurrency && defaultCurrency.code === 'SYP');
                const addThousands = (s) => {
                    if (!/^-?\d+(\.\d+)?$/.test(String(s))) return String(s);
                    const neg = String(s).startsWith('-');
                    const clean = neg ? String(s).slice(1) : String(s);
                    const parts = clean.split('.');
                    const intPart = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
                    const out = intPart + (parts[1] ? `.${parts[1]}` : '');
                    return neg ? ('\u200E-' + out) : out;
                };
                const fmt = (v) => {
                    if (v === null || v === undefined || v === '') return '0';
                    if (typeof v === 'string' && /^-?\d+(\.\d+)?$/.test(v.trim())) return v.trim();
                    const num = parseFloat(v);
                    if (isNaN(num)) return '0';
                    return isSYP ? String(Math.round(num)) : String(num);
                };
                const fmtTotal = (v) => {
                    const num = parseFloat(v);
                    if (!Number.isFinite(num)) return '0';
                    if (isSYP) return addThousands(String(Math.round(num)));
                    const normalized = Number.isInteger(num)
                        ? String(num)
                        : num.toFixed(6).replace(/0+$/,'').replace(/\.$/,'');
                    return addThousands(normalized);
                };
                let grandTotal = 0;
                
                (items || []).forEach(it => {
                    // الاعتماد على السعر النهائي لكل مادة في حساب الإجمالي
                    const unit = parseFloat(it.unit_cost) || 0;
                    const finalPrice = parseFloat(it.final_price) || 0;
                    const total = parseFloat(it.total_price) || 0;
                    grandTotal += total;
                });
	            %>
	            <input type="hidden" id="quotationGrandTotalValue" value="<%= grandTotal %>">

	            <!-- مودال التخيير -->
            <div class="card shadow mb-4">
                                <div id="quotationOutputModeModal" class="modal fade" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-sliders2 me-2 text-primary"></i> اختر نوع الطباعة</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                            </div>
                            <div class="modal-body">
                                <p class="mb-3">حدد طريقة الخصم ثم أدخل القيمة:</p>
                                <div class="mb-3">
                                    <label for="quotationDiscountType" class="form-label">نوع الخصم</label>
                                    <select id="quotationDiscountType" class="form-select">
                                        <option value="fixed">قيمة ثابتة</option>
                                        <option value="percent">نسبة مئوية</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="quotationDiscountedTotalInput" class="form-label">قيمة الخصم</label>
                                    <input id="quotationDiscountedTotalInput" type="text" inputmode="decimal" min="0" step="0.01" class="form-control" />
                                    <small id="quotationDiscountHelper" class="text-muted d-block mt-1">
                                        عند اختيار "قيمة ثابتة": الرقم هو مبلغ الخصم المباشر من الإجمالي الحالي.
                                    </small>
                                </div>
                                <div class="d-grid gap-2">
                                    <button id="quotationModeNormalBtn" type="button" class="btn btn-outline-secondary">
                                        عادي (عرض السعر الحالي)
                                    </button>
                                    <button id="quotationModeFullBtn" type="button" class="btn btn-outline-primary">
                                        كامل (يشمل كلفة الطرد + نسبة الربح)
                                    </button>
                                </div>
                                <div class="mt-3">
                                    <label for="quotationPrintLanguage" class="form-label">لغة الطباعة/التصدير</label>
                                    <select id="quotationPrintLanguage" class="form-select">
                                        <option value="ar" selected>العربية</option>
                                        <option value="en">English</option>
                                    </select>
                                    <small class="text-muted d-block mt-1">عند اختيار الإنكليزية سيتم ترجمة المحتوى العربي باستثناء الهيدر والفوتر.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>                <!-- PDF Export Modal -->
                <div id="quotationPdfExportModal" class="modal fade" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-file-earmark-pdf me-2 text-success"></i> تم إنشاء ملف PDF</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                            </div>
                            <div class="modal-body text-center">
                                <div class="mb-3">
                                    <input type="text" id="quotationPdfLinkInput" class="form-control text-center" readonly style="direction:ltr; font-size:0.95em;" />
                                </div>
                                <div class="d-flex justify-content-center gap-2 mb-2">
                                    <button id="copyQuotationPdfLinkBtn" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard me-1"></i> نسخ الرابط</button>
                                    <a id="openQuotationPdfLinkBtn" class="btn btn-outline-info btn-sm" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i> فتح الرابط</a>
                                    <a id="whatsappQuotationShareBtn" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-whatsapp me-1"></i> مشاركة عبر واتساب</a>
                                </div>
                                <div class="alert alert-success py-2 mb-0">يمكنك نسخ الرابط أو فتحه أو مشاركته عبر واتساب.</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-header">
                    <h5 class="mb-0">معلومات العرض</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless no-auto-num-center">
                                <tr>
                                    <td><strong>رقم العرض:</strong></td>
                                    <td><%= quotation.quotation_number %></td>
                                </tr>
                                <tr>
                                    <td><strong>التاريخ:</strong></td>
                                    <td><%= formatDate(quotation.created_at) %></td>
                                </tr>
                                <tr>
                                    <td><strong>اسم العميل:</strong></td>
                                    <td><%= quotation.client_name %></td>
                                </tr>
                                <tr>
                                    <td><strong>هاتف العميل:</strong></td>
                                    <td><%= quotation.client_phone || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>العنوان:</strong></td>
                                    <td><%= quotation.client_address || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>صفة البيع:</strong></td>
                                    <td><%= quotation.sale_description || '-' %></td>
                                </tr>
                                <tr>
                                    <td><strong>طريقة الدفع:</strong></td>
                                    <td><%= quotation.payment_method || '-' %></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless no-auto-num-center">
                                
                                <tr>
                                    <td><strong>الإجمالي النهائي:</strong></td>
                                    <td><strong class="text-primary">
                                        <%= fmtTotal(grandTotal) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </strong></td>
                                </tr>
                                <tr>
                                    <td><strong>عدد المواد:</strong></td>
                                    <td><%= items.length %></td>
                                </tr>
                                <tr>
                                    <td><strong>الملاحظات:</strong></td>
                                    <td><%= quotation.notes || '-' %></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- جدول المواد -->
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0">تفاصيل المواد</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>رقم المادة</th>
                                    <th>المادة</th>
                                    <th>نوع المادة</th>
                                    <th>التعبئة</th>
                                    <th>وزن التعبئة (كغ)</th>
                                    <th>عدد القطع</th>
                                    <th>كلفة الوحدة</th>
                                    <th>نسبة الربح</th>
                                    <th>سعر البيع</th>
                                    <th>الكمية</th>
                                    <th>الإجمالي</th>
                                    <th>ملاحظات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <%
                                    const groupedQuotationItemsMap = new Map();
                                    (items || []).forEach((it) => {
                                        const key = (it.material_name || '').trim();
                                        if (!groupedQuotationItemsMap.has(key)) groupedQuotationItemsMap.set(key, []);
                                        groupedQuotationItemsMap.get(key).push(it);
                                    });
                                    const groupedQuotationItems = Array.from(groupedQuotationItemsMap.values());
                                %>
                                <% groupedQuotationItems.forEach((group) => { %>
                                <% group.forEach((item, indexInGroup) => {
                                     const unit = item.unit_cost;
                                     const final = item.final_price;
                                     const total = item.total_price;
                                %>
                                <tr>
                                    <td><%= item.material_id || '-' %></td>
                                    <% if (indexInGroup === 0) { %>
                                    <td rowspan="<%= group.length %>"><%= item.material_name %></td>
                                    <% } %>
                                    <td><%= item.material_type || '-' %></td>
                                    <td><%= item.packaging_unit || '-' %></td>
                                    <td>
                                        <% if (item.packaging_weight != null) { %>
                                            <%= fmt(item.packaging_weight) %>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                    <td><%= item.pieces_per_package || '-' %></td>
                                    <td>
                                        <%= fmt(unit) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                    <td><%= fmt(item.profit_percentage) %>%</td>
                                    <td>
                                        <%= fmt(final) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </td>
                                    <td><%= item.quantity %></td>
                                    <td>
                                        <strong><%= fmt(total) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %></strong>
                                    </td>
                                    <td><%= item.item_notes || '-' %></td>
                                </tr>
                                <% }); %>
                                <% }); %>
                            </tbody>
                            <tfoot>
                                <tr class="table-info">
                                    <td colspan="10" class="text-end"><strong>الإجمالي النهائي:</strong></td>
                                    <td><strong>
                                        <%= fmtTotal(grandTotal) %> <%= defaultCurrency ? defaultCurrency.symbol : '$' %>
                                    </strong></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ملاحظات إضافية -->
            <% if (quotation.notes) { %>
            <div class="card shadow mt-4">
                <div class="card-header">
                    <h5 class="mb-0">ملاحظات</h5>
                </div>
                <div class="card-body">
                    <p><%= quotation.notes %></p>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const printBtn = document.getElementById('printQuotationBtn');
    const exportBtn = document.getElementById('exportQuotationPdfBtn');
    const quotationGrandTotal = Number(document.getElementById('quotationGrandTotalValue')?.value || 0);
    const outputModeModalElem = document.getElementById('quotationOutputModeModal');
    const outputModeModal = outputModeModalElem ? new bootstrap.Modal(outputModeModalElem) : null;
    const modeNormalBtn = document.getElementById('quotationModeNormalBtn');
    const modeFullBtn = document.getElementById('quotationModeFullBtn');
    const discountedTotalInput = document.getElementById('quotationDiscountedTotalInput');
    const discountTypeSelect = document.getElementById('quotationDiscountType');
    const quotationPrintLanguage = document.getElementById('quotationPrintLanguage');
    const discountHelper = document.getElementById('quotationDiscountHelper');
    const modalElem = document.getElementById('quotationPdfExportModal');
    const modal = modalElem ? new bootstrap.Modal(modalElem) : null;
    const linkInput = document.getElementById('quotationPdfLinkInput');
    const copyBtn = document.getElementById('copyQuotationPdfLinkBtn');
    const openBtn = document.getElementById('openQuotationPdfLinkBtn');
    const waBtn = document.getElementById('whatsappQuotationShareBtn');

    let pendingOutputAction = null;

    function openOutputModeChooser(action) {
        pendingOutputAction = action;
        if (discountTypeSelect) {
            discountTypeSelect.value = 'fixed';
        }
        if (discountedTotalInput) {
            discountedTotalInput.value = '0';
        }
        updateQuotationDiscountHelper();
        if (outputModeModal) outputModeModal.show();
    }

    function updateQuotationDiscountHelper() {
        if (!discountHelper) return;
        enforceQuotationDiscountLimits();
        const mode = discountTypeSelect ? discountTypeSelect.value : 'fixed';
        const enteredValue = parseFloat(discountedTotalInput?.value || '0');
        const numericValue = Number.isFinite(enteredValue) ? enteredValue : 0;
        const total = quotationGrandTotal;
        let discountAmount = 0;

        if (mode === 'percent') {
            discountAmount = Math.max(0, Math.min(100, numericValue)) * total / 100;
        } else {
            discountAmount = Math.max(0, Math.min(total, numericValue));
        }

        const afterDiscount = Math.max(0, total - discountAmount);
        if (mode === 'percent') {
            discountHelper.textContent = `سيتم خصم ${numericValue}% من الإجمالي الحالي، أي خصم ${discountAmount.toFixed(2)}، ليصبح الإجمالي بعد الخصم ${afterDiscount.toFixed(2)}.`;
        } else {
            discountHelper.textContent = `سيتم خصم قيمة ثابتة مقدارها ${discountAmount.toFixed(2)} من الإجمالي الحالي، ليصبح الإجمالي بعد الخصم ${afterDiscount.toFixed(2)}.`;
        }
    }

    function getValidatedDiscountedTotal() {
        if (!discountedTotalInput) return quotationGrandTotal;
        enforceQuotationDiscountLimits();
        const mode = discountTypeSelect ? discountTypeSelect.value : 'fixed';
        const rawValue = parseFloat(discountedTotalInput.value);
        if (!Number.isFinite(rawValue)) {
            alert('يرجى إدخال رقم صالح.');
            discountedTotalInput.focus();
            return null;
        }

        let discountAmount = 0;
        if (mode === 'percent') {
            if (rawValue < 0 || rawValue > 100) {
                alert('النسبة المئوية يجب أن تكون بين 0 و 100.');
                discountedTotalInput.focus();
                return null;
            }
            discountAmount = (quotationGrandTotal * rawValue) / 100;
        } else {
            if (rawValue < 0) {
                alert('قيمة الخصم الثابت لا يمكن أن تكون أقل من صفر.');
                discountedTotalInput.focus();
                return null;
            }
            if (rawValue > quotationGrandTotal) {
                alert('قيمة الخصم الثابت لا يمكن أن تكون أكبر من الإجمالي الحالي.');
                discountedTotalInput.focus();
                return null;
            }
            discountAmount = rawValue;
        }

        return Math.max(0, quotationGrandTotal - discountAmount);
    }

    function enforceQuotationDiscountLimits() {
        if (!discountedTotalInput) return;
        const mode = discountTypeSelect ? discountTypeSelect.value : 'fixed';
        const raw = (discountedTotalInput.value || '').trim();
        if (!raw) return;
        let value = parseFloat(raw);
        if (!Number.isFinite(value)) return;
        if (value < 0) value = 0;
        if (mode === 'percent') {
            if (value > 100) value = 100;
        } else {
            if (value > quotationGrandTotal) value = quotationGrandTotal;
        }
        if (String(value) !== raw) {
            discountedTotalInput.value = String(value);
        }
    }

    async function exportPdfByMode(mode, discountedTotalValue) {
        if (!exportBtn) return;
            const lang = quotationPrintLanguage ? quotationPrintLanguage.value : 'ar';
            exportBtn.disabled = true;
            exportBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> جاري التصدير...';
            try {
            const res = await fetch(`/costs/quotations/<%= quotation.id %>/pdf?mode=${encodeURIComponent(mode)}&discounted_total=${encodeURIComponent(discountedTotalValue)}&lang=${encodeURIComponent(lang)}`);
                const data = await res.json();
                if (data.success && data.url) {
                    if (linkInput) linkInput.value = data.url;
                    if (openBtn) openBtn.href = data.url;
                    if (waBtn) waBtn.href = `https://wa.me/?text=${encodeURIComponent(data.url)}`;
                    if (modal) modal.show();
                } else {
                    alert(data.message || 'تعذر إنشاء ملف PDF');
                }
            } catch (e) {
                alert('حدث خطأ في التصدير');
            }
            exportBtn.disabled = false;
            exportBtn.innerHTML = '<i class="bi bi-file-earmark-pdf"></i> تصدير PDF';
    }

    function printByMode(mode, discountedTotalValue) {
        const lang = quotationPrintLanguage ? quotationPrintLanguage.value : 'ar';
        window.open(`/costs/quotations/<%= quotation.id %>/print?mode=${encodeURIComponent(mode)}&discounted_total=${encodeURIComponent(discountedTotalValue)}&lang=${encodeURIComponent(lang)}`, '_blank');
    }

    async function handleModeSelection(mode) {
        const discountedTotalValue = getValidatedDiscountedTotal();
        if (discountedTotalValue === null) return;
        if (outputModeModal) outputModeModal.hide();
        if (pendingOutputAction === 'print') {
            printByMode(mode, discountedTotalValue);
            return;
        }
        if (pendingOutputAction === 'export') {
            await exportPdfByMode(mode, discountedTotalValue);
        }
    }

    if (printBtn) {
        printBtn.addEventListener('click', function () {
            openOutputModeChooser('print');
        });
    }
    if (exportBtn) {
        exportBtn.addEventListener('click', function () {
            openOutputModeChooser('export');
        });
    }
    if (modeNormalBtn) {
        modeNormalBtn.addEventListener('click', function () {
            handleModeSelection('normal');
        });
    }
    if (modeFullBtn) {
        modeFullBtn.addEventListener('click', function () {
            handleModeSelection('full');
        });
    }
    if (discountTypeSelect) {
        discountTypeSelect.addEventListener('change', function () {
            if (discountTypeSelect.value === 'percent') {
                discountedTotalInput?.setAttribute('max', '100');
            } else {
                discountedTotalInput?.setAttribute('max', String(quotationGrandTotal));
            }
            updateQuotationDiscountHelper();
        });
    }
    if (discountedTotalInput) {
        discountedTotalInput.addEventListener('input', updateQuotationDiscountHelper);
    }
    if (discountTypeSelect && discountTypeSelect.value === 'percent') {
        discountedTotalInput?.setAttribute('max', '100');
    } else {
        discountedTotalInput?.setAttribute('max', String(quotationGrandTotal));
    }
    updateQuotationDiscountHelper();
    if (copyBtn && linkInput) {
        copyBtn.addEventListener('click', function () {
            linkInput.select();
            document.execCommand('copy');
        });
    }
});
</script>
<style>
