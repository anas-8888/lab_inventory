<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-journal-text"></i> الملاحظات</h2>
    <div class="notes-top-actions">
      <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-right"></i> رجوع</a>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createNoteModal">
        <i class="bi bi-plus-circle"></i> إضافة ملاحظة
      </button>
    </div>
  </div>

  <% if (notes && notes.length) { %>
  <div class="card shadow">
    <div class="card-header">
      <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
        <h5 class="mb-0">جدول الملاحظات</h5>
        <div class="d-flex gap-2 align-items-center">
          <button type="button" id="notesExportSelectedBtn" class="btn btn-sm btn-outline-success d-none notes-export-btn"><span class="d-block">تصدير</span></button>
          <div class="input-group" style="max-width: 360px;">
            <input type="text" id="notesSearchInput" class="form-control" placeholder="بحث">
          </div>
        </div>
      </div>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle notes-table">
          <thead>
            <tr>
              <th class="text-center" style="width: 38px;">
                <input type="checkbox" class="form-check-input" id="notesSelectAll" aria-label="تحديد الكل">
              </th>
              <th>#</th>
              <th>اسم المادة</th>
              <th>السعر</th>
              <th>الوزن</th>
              <th>التاريخ</th>
              <th>الملاحظات</th>
              <th>الإجراءات</th>
            </tr>
          </thead>
          <tbody id="notesTableBody">
            <% notes.forEach((n, idx) => { %>
              <tr>
                <td class="text-center">
                  <input type="checkbox" class="form-check-input note-checkbox" data-id="<%= n.id %>">
                </td>
                <td><%= idx + 1 %></td>
                <td><%= n.material_name || ('#' + (n.material_id || '-')) %></td>
                <td><%= (n.price != null) ? n.price : '-' %></td>
                <td><%= (n.weight != null) ? n.weight : '-' %></td>
                <td><%= n.note_date || '-' %></td>
                <td class="text-truncate" style="max-width:260px;"><%= n.note_text || '-' %></td>
                <td>
                  <div class="btn-group">
                    <a href="/notes/<%= n.id %>" class="btn btn-sm btn-secondary" title="عرض"><i class="bi bi-eye"></i></a>
                    <button type="button" class="btn btn-sm btn-info js-note-edit" data-note-id="<%= n.id %>" title="تعديل"><i class="bi bi-pencil"></i></button>
                    <button type="button" class="btn btn-sm btn-danger js-note-delete" data-note-id="<%= n.id %>" title="حذف"><i class="bi bi-trash"></i></button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div id="notesNoResults" class="text-center text-muted py-3 d-none">لا توجد نتائج مطابقة</div>
      </div>
    </div>
  </div>
  <% } else { %>
    <div class="card shadow">
      <div class="card-body text-center py-5">
        <i class="bi bi-journal-x fs-1 text-muted mb-3"></i>
        <h5 class="mb-2">لا توجد ملاحظات حتى الآن</h5>
        <p class="text-muted">ابدأ بإضافة أول ملاحظة باستخدام الزر أعلاه.</p>
      </div>
    </div>
  <% } %>

  <!-- Create Modal -->
  <div class="modal fade" id="createNoteModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">إضافة ملاحظة</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <form id="createNoteForm">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">اسم المادة (اختياري)</label>
                <input type="text" class="form-control" name="material_name" placeholder="أدخل اسم المادة كنص">
              </div>
              <div class="col-md-3">
                <label class="form-label">السعر</label>
                <input type="text" inputmode="decimal" class="form-control" name="price" placeholder="اختياري">
              </div>
              <div class="col-md-3">
                <label class="form-label">الوزن (كغ)</label>
                <input type="text" inputmode="decimal" class="form-control" name="weight" placeholder="اختياري">
              </div>
              
              <div class="col-12">
                <label class="form-label">ملاحظات</label>
                <textarea class="form-control" rows="3" name="note_text"></textarea>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
          <button type="button" class="btn btn-primary" onclick="submitCreate()">حفظ</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Modal -->
  <div class="modal fade" id="editNoteModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">تعديل ملاحظة</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <form id="editNoteForm">
            <input type="hidden" name="id" id="editNoteId">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">اسم المادة (اختياري)</label>
                <input type="text" class="form-control" name="material_name" id="editMaterialName" placeholder="أدخل اسم المادة كنص">
              </div>
              <div class="col-md-3">
                <label class="form-label">السعر</label>
                <input type="text" inputmode="decimal" class="form-control" name="price" id="editPrice">
              </div>
              <div class="col-md-3">
                <label class="form-label">الوزن (كغ)</label>
                <input type="text" inputmode="decimal" class="form-control" name="weight" id="editWeight">
              </div>
              
              <div class="col-12">
                <label class="form-label">ملاحظات</label>
                <textarea class="form-control" rows="3" name="note_text" id="editText"></textarea>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
          <button type="button" class="btn btn-primary" onclick="submitEdit()">حفظ التعديلات</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function submitCreate(){
  const form = document.getElementById('createNoteForm');
  const fd = new FormData(form);
  fetch('/notes', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(Object.fromEntries(fd)) })
    .then(r=>r.json()).then(d=>{ if(d.success){ location.reload(); } else { alert(d.message||'فشل الحفظ'); } });
}
function openEditModal(id){
  fetch('/notes/'+id, { headers: { 'Accept':'application/json' } })
    .then(r=> r.ok ? r.json() : Promise.reject())
    .then(data=>{
      const n = data.note;
      document.getElementById('editNoteId').value = n.id;
      const editName = document.getElementById('editMaterialName');
      if (editName) editName.value = (n.material_name && n.material_name.trim()) ? n.material_name : (n.material_id ? ('#'+n.material_id) : '');
      document.getElementById('editPrice').value = (n.price!=null? n.price: '');
      document.getElementById('editWeight').value = (n.weight!=null? n.weight: '');
      document.getElementById('editText').value = n.note_text || '';
      new bootstrap.Modal(document.getElementById('editNoteModal')).show();
    })
    .catch(()=> window.location.href = '/notes/'+id);
}
function submitEdit(){
  const fd = new FormData(document.getElementById('editNoteForm'));
  const id = fd.get('id');
  fetch('/notes/'+id, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(Object.fromEntries(fd)) })
    .then(r=>r.json()).then(d=>{ if(d.success){ location.reload(); } else { alert(d.message||'فشل التعديل'); } });
}
function deleteNote(id){
  if(!confirm('هل أنت متأكد من حذف هذه الملاحظة؟')) return;
  fetch('/notes/'+id, { method:'DELETE' }).then(r=>r.json()).then(d=>{ if(d.success){ location.reload(); } else { alert(d.message||'فشل الحذف'); } });
}


document.addEventListener('click', (event) => {
  const editBtn = event.target.closest('.js-note-edit');
  if (editBtn) {
    const id = Number(editBtn.dataset.noteId);
    if (Number.isFinite(id)) openEditModal(id);
    return;
  }

  const deleteBtn = event.target.closest('.js-note-delete');
  if (deleteBtn) {
    const id = Number(deleteBtn.dataset.noteId);
    if (Number.isFinite(id)) deleteNote(id);
  }
});

function applyNotesSearch() {
  const input = document.getElementById('notesSearchInput');
  const body = document.getElementById('notesTableBody');
  if (!input || !body) return;
  const query = input.value.trim().toLowerCase();
  const rows = Array.from(body.querySelectorAll('tr'));
  let anyVisible = false;
  rows.forEach(row => {
    const cells = row.querySelectorAll('td');
    const haystack = [
      cells[2]?.textContent || '',
      cells[3]?.textContent || '',
      cells[4]?.textContent || '',
      cells[5]?.textContent || '',
      cells[6]?.textContent || ''
    ].join(' ').toLowerCase();
    const show = query === '' || haystack.includes(query);
    row.classList.toggle('d-none', !show);
    if (show) anyVisible = true;
  });
  const empty = document.getElementById('notesNoResults');
  if (empty) empty.classList.toggle('d-none', anyVisible);
}

const notesSearchInput = document.getElementById('notesSearchInput');
if (notesSearchInput) {
  notesSearchInput.addEventListener('input', applyNotesSearch);
}

function updateNotesSelectionUi() {
  const checkboxes = Array.from(document.querySelectorAll('.note-checkbox'));
  const checked = checkboxes.filter(cb => cb.checked);
  const selectAll = document.getElementById('notesSelectAll');
  if (selectAll) {
    const allChecked = checkboxes.length > 0 && checked.length === checkboxes.length;
    selectAll.checked = allChecked;
    selectAll.indeterminate = checked.length > 0 && !allChecked;
  }
  checkboxes.forEach(cb => {
    const row = cb.closest('tr');
    if (row) row.classList.toggle('notes-row-selected', cb.checked);
  });
  const exportBtn = document.getElementById('notesExportSelectedBtn');
  if (exportBtn) {
    if (checked.length > 0) {
      exportBtn.classList.remove('d-none');
      exportBtn.disabled = false;
      exportBtn.innerHTML = '<span class="d-block">تصدير</span>';
    } else {
      exportBtn.classList.add('d-none');
      exportBtn.disabled = true;
      exportBtn.innerHTML = '<span class="d-block">تصدير</span>';
    }
  }
}

const notesSelectAll = document.getElementById('notesSelectAll');
if (notesSelectAll) {
  notesSelectAll.addEventListener('change', () => {
    const checkboxes = document.querySelectorAll('.note-checkbox');
    checkboxes.forEach(cb => { cb.checked = notesSelectAll.checked; });
    updateNotesSelectionUi();
  });
}

document.querySelectorAll('.note-checkbox').forEach(cb => {
  cb.addEventListener('change', updateNotesSelectionUi);
});

const notesExportSelectedBtn = document.getElementById('notesExportSelectedBtn');
if (notesExportSelectedBtn) {
  notesExportSelectedBtn.addEventListener('click', async () => {
    const checked = Array.from(document.querySelectorAll('.note-checkbox:checked'));
    if (checked.length === 0) {
      alert('يرجى تحديد ملاحظات للتصدير');
      return;
    }
    notesExportSelectedBtn.disabled = true;
    notesExportSelectedBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    try {
      const res = await fetch('/exports/notes/pdf-selected', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: checked.map(cb => Number(cb.dataset.id)).filter(Boolean) })
      });
      const data = await res.json();
      if (data.success && data.url) {
        const linkInput = document.getElementById('notesListPdfLinkInput');
        const openBtn = document.getElementById('openNotesListPdfLinkBtn');
        const waBtn = document.getElementById('whatsappNotesListShareBtn');
        if (linkInput) linkInput.value = data.url;
        if (openBtn) openBtn.href = data.url;
        if (waBtn) waBtn.href = `https://wa.me/?text=${encodeURIComponent(data.url)}`;
        const modal = new bootstrap.Modal(document.getElementById('notesListPdfExportModal'));
        modal.show();
      } else {
        alert(data.message || 'حدث خطأ أثناء إنشاء ملف PDF');
      }
    } catch (e) {
      alert('حدث خطأ في الاتصال بالخادم');
    } finally {
      notesExportSelectedBtn.disabled = false;
      notesExportSelectedBtn.innerHTML = '<span class="d-block">تصدير</span>';
    }
  });
}

const copyNotesPdfBtn = document.getElementById('copyNotesListPdfLinkBtn');
const notesPdfInput = document.getElementById('notesListPdfLinkInput');
if (copyNotesPdfBtn && notesPdfInput) {
  copyNotesPdfBtn.addEventListener('click', function () {
    notesPdfInput.select();
    document.execCommand('copy');
  });
}

updateNotesSelectionUi();
</script>

<!-- Export PDF Modal -->
<div id="notesListPdfExportModal" class="modal fade" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-file-earmark-pdf me-2 text-success"></i> تم إنشاء ملف PDF</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
      </div>
      <div class="modal-body text-center">
        <div class="mb-3">
          <input type="text" id="notesListPdfLinkInput" class="form-control text-center" readonly style="direction:ltr; font-size:0.95em;" />
        </div>
        <div class="d-flex justify-content-center gap-2 mb-2">
          <button id="copyNotesListPdfLinkBtn" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard me-1"></i> نسخ الرابط</button>
          <a id="openNotesListPdfLinkBtn" class="btn btn-outline-info btn-sm" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i> فتح الرابط</a>
          <a id="whatsappNotesListShareBtn" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-whatsapp me-1"></i> إرسال عبر واتساب</a>
        </div>
        <div class="alert alert-success py-2 mb-0">يمكنك مشاركة الرابط مع أي شخص لتحميل الملف مباشرة</div>
      </div>
    </div>
  </div>
</div>



