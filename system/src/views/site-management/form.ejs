<%
  const productDefs = [
    { key: 'olive_products', label: 'منتجات الزيتون' },
    { key: 'olive_oil', label: 'زيت الزيتون' },
    { key: 'agri_crops', label: 'المحاصيل الزراعية' }
  ];
  const productSections = formData.productSections || {};
  const inboxMessages = Array.isArray(locals.inboxMessages) ? locals.inboxMessages : [];
%>

<div class="container mt-4">
  <style>
    .site-image-preview { width: 100%; max-width: 200px; height: 130px; object-fit: cover; border: 1px solid #dee2e6; border-radius: 8px; margin-top: 8px; background: #f8f9fa; }
    .product-row-card { border: 1px solid #e9ecef; border-radius: 10px; padding: 14px; margin-bottom: 10px; background: #fff; }
    .product-section-toggle { font-weight: 700; }
    .product-section-head { background: #f8fafc; }
    .product-help-text { font-size: 12px; color: #6c757d; }
    #siteTabs .nav-link {
      color: #198754;
      border: 1px solid #198754;
      background-color: #fff;
      margin-left: 6px;
    }
    #siteTabs .nav-link:hover {
      color: #fff;
      background-color: #198754;
    }
    #siteTabs .nav-link.active {
      color: #fff;
      background-color: #198754;
      border-color: #198754;
    }
    .product-card-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
    .product-card-click { cursor: pointer; background: #fff; }
    .product-thumb { width: 90px; height: 90px; object-fit: cover; border-radius: 10px; border: 1px solid #e5e7eb; background: #f8f9fa; }
    .product-card-title { font-weight: 700; margin-bottom: 2px; }
    .product-card-sub { color: #6c757d; font-size: 13px; margin-bottom: 2px; }
    .product-card-foot { background: #f8fafc; border-top: 1px solid #e5e7eb; }
    .category-preview-box { border: 1px dashed #ced4da; border-radius: 10px; background: #f8f9fa; padding: 10px; }
    .category-chip { display: inline-block; background: #e8f5ec; color: #0f5132; border: 1px solid #c3e6cb; border-radius: 999px; padding: 2px 10px; font-size: 12px; margin: 0 6px 6px 0; }
    .contact-group-card { border: 1px solid #e9ecef; border-radius: 10px; }
    .contact-group-title { font-size: 15px; font-weight: 700; color: #14532d; margin-bottom: 12px; }
    .inbox-message-card { border: 1px solid #e5e7eb; border-radius: 10px; background: #fff; }
    .inbox-meta { font-size: 12px; color: #6b7280; }
    .inbox-attachment-img { width: 72px; height: 72px; object-fit: cover; border-radius: 8px; border: 1px solid #dee2e6; }
    .products-table .product-thumb { width: 64px; height: 64px; border-radius: 8px; }
    .products-table .js-card-image { cursor: zoom-in; transition: transform 0.15s ease; }
    .products-table .js-card-image:hover { transform: scale(1.04); }
    .products-table .drag-col { width: 56px; }
    .drag-handle-btn { cursor: grab; }
    .drag-handle-btn:active { cursor: grabbing; }
    .product-row.product-row-dragging { opacity: 0.7; background: #eef9f1; }
    .accordion-button.product-section-toggle:not(.collapsed) {
      background-color: #f8fafc;
      color: #212529;
      box-shadow: none;
    }
    .accordion-button.product-section-toggle:focus {
      border-color: #198754;
      box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.15);
    }
    .product-modal-image-preview { width: 100%; max-width: 180px; height: 120px; object-fit: cover; border: 1px solid #dee2e6; border-radius: 10px; background: #f8f9fa; }
    .products-table .product-long-cell {
      max-width: 220px;
      white-space: pre-line;
      word-break: break-word;
      font-size: 12px;
      line-height: 1.4;
    }
    .products-table td, .products-table th { vertical-align: middle; text-align: center; }
    .products-table thead th { text-align: center; }
    .product-image-preview-modal .modal-content { border-radius: 14px; overflow: hidden; }
    .product-image-preview-modal .modal-body { padding: 0.75rem; text-align: center; background: #f8f9fa; }
    .product-image-preview-modal img { max-width: 100%; max-height: 78vh; width: auto; height: auto; border-radius: 8px; object-fit: contain; }
  </style>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-globe2 me-2"></i>تعديل إدارة الموقع</h2>
    <a href="/site-management" class="btn btn-outline-secondary"><i class="bi bi-arrow-right me-1"></i> رجوع</a>
  </div>

  <ul class="nav nav-pills mb-3" id="siteTabs" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tab-navbar" type="button">اللوغو</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-products" type="button">المنتجات</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-inbox" type="button">البريد الوارد</button></li>
  </ul>

  <form id="siteManagementForm" method="POST" action="/site-management/<%= currentRecord.id %>/update" enctype="multipart/form-data">
    <div class="tab-content">
      <div class="tab-pane fade show active" id="tab-navbar">
        <div class="card shadow-sm mb-3">
          <div class="card-header"><strong>اللوغو والأيقونة</strong></div>
          <div class="card-body row g-3">
            <div class="col-md-6">
              <label class="form-label">صورة اللوغو</label>
              <input type="hidden" name="current_logo_image" value="<%= formData.current_logo_image || '' %>">
              <input id="logoImageInput" class="form-control" type="file" name="logo_image_file" accept="image/*">
              <img
                id="logoPreviewImage"
                src="<%= formData.current_logo_image || '' %>"
                data-existing-src="<%= formData.current_logo_image || '' %>"
                class="site-image-preview <%= formData.current_logo_image ? '' : 'd-none' %>"
                alt="logo"
              >
              <div id="logoPreviewHint" class="small text-muted mt-1 <%= formData.current_logo_image ? 'd-none' : '' %>">
                لا توجد صورة حالية.
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label">صورة الأيقونة</label>
              <input type="hidden" name="current_logo_icon" value="<%= formData.current_logo_icon || '' %>">
              <input id="iconImageInput" class="form-control" type="file" name="logo_icon_file" accept="image/*">
              <img
                id="iconPreviewImage"
                src="<%= formData.current_logo_icon || '' %>"
                data-existing-src="<%= formData.current_logo_icon || '' %>"
                class="site-image-preview <%= formData.current_logo_icon ? '' : 'd-none' %>"
                alt="logo-icon"
              >
              <div id="iconPreviewHint" class="small text-muted mt-1 <%= formData.current_logo_icon ? 'd-none' : '' %>">
                لا توجد صورة حالية.
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tab-products">
        <div class="card shadow-sm mb-3">
          <div class="card-header"><strong>المنتجات - الأقسام الثلاثة</strong></div>
          <div class="card-body">
            <div class="accordion" id="productsSectionsAccordion">
              <% productDefs.forEach((def) => { const section = productSections[def.key] || {}; const items = section.items || []; const sectionCollapseId = `collapse_${def.key}`; const sectionHeaderId = `header_${def.key}`; %>
                <div class="accordion-item mb-2">
                  <h2 class="accordion-header product-section-head" id="<%= sectionHeaderId %>">
                    <button class="accordion-button product-section-toggle collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#<%= sectionCollapseId %>" aria-expanded="false" aria-controls="<%= sectionCollapseId %>">
                      <span><%= def.label %></span>
                      <span class="badge bg-secondary ms-2">عدد المنتجات: <%= items.length %></span>
                      <span class="badge bg-success ms-2 js-category-count-pill" data-section="<%= def.key %>">عدد الفئات: <%= (section.categories_ar_text || '').split(/\r?\n/).filter(Boolean).length %></span>
                    </button>
                  </h2>
                  <div id="<%= sectionCollapseId %>" class="accordion-collapse collapse" aria-labelledby="<%= sectionHeaderId %>" data-bs-parent="#productsSectionsAccordion">
                    <div class="accordion-body">
                      <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                          <label class="form-label mb-0 fw-bold">فئات <%= def.label %></label>
                          <button
                            type="button"
                            class="btn btn-sm btn-outline-success add-category-btn"
                            data-section="<%= def.key %>"
                            data-label="<%= def.label %>"
                          >
                            <i class="bi bi-plus-circle"></i> إضافة فئة
                          </button>
                        </div>
                        <div id="<%= def.key %>_categories_list" class="category-preview-box d-flex flex-column gap-2"></div>
                        <textarea class="d-none categories-ar-storage" data-section="<%= def.key %>" name="<%= def.key %>_categories_ar_text"><%= section.categories_ar_text || '' %></textarea>
                        <textarea class="d-none categories-en-storage" data-section="<%= def.key %>" name="<%= def.key %>_categories_en_text"><%= section.categories_en_text || '' %></textarea>
                      </div>

                      <div class="d-flex justify-content-between align-items-center mb-2 mt-3">
                        <label class="form-label mb-0 fw-bold">منتجات <%= def.label %></label>
                        <button type="button" class="btn btn-sm btn-outline-primary add-product-btn" data-section="<%= def.key %>"><i class="bi bi-plus-circle"></i> إضافة منتج</button>
                      </div>

                      <div class="table-responsive">
                        <table class="table table-bordered table-hover products-table mb-0">
                          <thead class="table-light">
                            <tr>
                              <th class="drag-col">سحب</th>
                              <th style="width:90px;">الصورة</th>
                              <th>الاسم عربي</th>
                              <th>الاسم EN</th>
                              <th>الفئة</th>
                              <th>الوصف عربي</th>
                              <th>الوصف EN</th>
                              <th>المميزات عربي</th>
                              <th>المميزات EN</th>
                              <th style="width:170px;">الإجراءات</th>
                            </tr>
                          </thead>
                          <tbody id="<%= def.key %>_products_container">
                        <% items.forEach((p, idx) => { %>
                          <tr class="product-row" data-section="<%= def.key %>" draggable="false">
                            <td>
                              <button type="button" class="btn btn-sm btn-light border drag-handle-btn" title="سحب لإعادة الترتيب" aria-label="سحب لإعادة الترتيب">
                                <i class="bi bi-grip-vertical"></i>
                              </button>
                            </td>
                            <td><img class="product-thumb js-card-image" src="<%= p.current_image || '/public/img/placeholder-image.png' %>" alt="product-image"></td>
                            <td class="js-name-ar"><%= p.name_ar || 'منتج بدون اسم' %></td>
                            <td class="js-name-en"><%= p.name_en || '-' %></td>
                            <td class="js-category-ar"><%= p.category_ar || '-' %></td>
                            <td class="js-description-ar product-long-cell"><%= p.description_ar || '-' %></td>
                            <td class="js-description-en product-long-cell"><%= p.description_en || '-' %></td>
                            <td class="js-features-ar product-long-cell"><%= p.features_ar || '-' %></td>
                            <td class="js-features-en product-long-cell"><%= p.features_en || '-' %></td>
                            <td>
                              <div class="d-flex gap-1">
                                <button type="button" class="btn btn-sm btn-outline-primary js-edit-product" title="تعديل المنتج" aria-label="تعديل المنتج"><i class="bi bi-pencil-square"></i></button>
                                <button
                                  type="button"
                                  class="btn btn-sm btn-outline-secondary duplicate-product-btn"
                                  title="استنساخ المنتج"
                                  aria-label="استنساخ المنتج"
                                >
                                  <i class="bi bi-files"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger product-delete-btn" title="حذف المنتج" aria-label="حذف المنتج"><i class="bi bi-trash"></i></button>
                              </div>
                              <input type="hidden" data-field="id" name="<%= def.key %>_product_id" value="<%= p.id || '' %>">
                              <input type="hidden" data-field="category_ar" name="<%= def.key %>_product_category_ar" value="<%= p.category_ar || '' %>">
                              <input type="hidden" data-field="category_en" name="<%= def.key %>_product_category_en" value="<%= p.category_en || '' %>">
                              <input type="hidden" data-field="name_ar" name="<%= def.key %>_product_name_ar" value="<%= p.name_ar || '' %>">
                              <input type="hidden" data-field="name_en" name="<%= def.key %>_product_name_en" value="<%= p.name_en || '' %>">
                              <textarea class="d-none" data-field="description_ar" name="<%= def.key %>_product_description_ar"><%= p.description_ar || '' %></textarea>
                              <textarea class="d-none" data-field="description_en" name="<%= def.key %>_product_description_en"><%= p.description_en || '' %></textarea>
                              <textarea class="d-none" data-field="features_ar" name="<%= def.key %>_product_features_ar"><%= p.features_ar || '' %></textarea>
                              <textarea class="d-none" data-field="features_en" name="<%= def.key %>_product_features_en"><%= p.features_en || '' %></textarea>
                              <input class="d-none section-product-image-input" type="file" name="<%= def.key %>_product_image_<%= idx %>" accept="image/*">
                              <input type="hidden" data-field="current_image" name="<%= def.key %>_current_product_image" value="<%= p.current_image || '' %>">
                            </td>
                          </tr>
                        <% }) %>
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tab-inbox">
        <div class="card shadow-sm mb-3">
          <div class="card-header d-flex justify-content-between align-items-center">
            <strong>البريد الوارد</strong>
            <span class="badge bg-success">عدد الرسائل: <%= inboxMessages.length %></span>
          </div>
          <div class="card-body">
            <% if (!inboxMessages.length) { %>
              <div class="text-muted">لا توجد رسائل حتى الآن.</div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th class="text-center" style="width: 60px;">#</th>
                      <th class="text-center" style="min-width: 150px;">المرسل</th>
                      <th class="text-center" style="min-width: 130px;">الرقم</th>
                      <th class="text-center" style="min-width: 280px;">الرسالة</th>
                      <th class="text-center" style="min-width: 150px;">التاريخ</th>
                      <th class="text-center" style="min-width: 160px;">IP</th>
                      <th class="text-center" style="min-width: 180px;">المرفقات</th>
                      <th class="text-center" style="width: 90px;">حذف</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% inboxMessages.forEach((mail, idx) => { %>
                      <tr>
                        <td class="text-center"><%= idx + 1 %></td>
                        <td><strong><%= mail.sender_name || '-' %></strong></td>
                        <td dir="ltr"><%= mail.sender_phone || '-' %></td>
                        <td style="white-space: pre-wrap;"><%= mail.message_text || '-' %></td>
                        <td class="text-center"><%= mail.created_at_display || '-' %></td>
                        <td class="text-center"><code><%= mail.sender_ip || '-' %></code></td>
                        <td>
                          <% if (mail.attachments && mail.attachments.length) { %>
                            <div class="d-flex flex-wrap gap-2">
                              <% mail.attachments.forEach((att) => { %>
                                <a href="<%= att.file_url %>" class="js-inbox-attachment-link" data-image-url="<%= att.file_url %>" data-image-alt="attachment">
                                  <img src="<%= att.file_url %>" class="inbox-attachment-img" alt="attachment">
                                </a>
                              <% }) %>
                            </div>
                          <% } else { %>
                            <span class="text-muted small">لا يوجد</span>
                          <% } %>
                        </td>
                        <td class="text-center">
                          <button
                            type="button"
                            class="btn btn-sm btn-outline-danger delete-inbox-message-btn"
                            data-message-id="<%= mail.id %>"
                            title="حذف الرسالة"
                            aria-label="حذف الرسالة"
                          >
                            <i class="bi bi-trash"></i>
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

  </form>
  <form id="deleteInboxMessageForm" method="POST" class="d-none"></form>
</div>

<div class="modal fade" id="productEditorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">إضافة منتج جديد</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="card border-0 bg-light-subtle mb-3">
          <div class="card-body">
            <h6 class="mb-3 text-success">البيانات الأساسية</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">اسم المنتج (عربي)</label>
                <input id="pm_name_ar" class="form-control" placeholder="مثال: زيت زيتون بكر ممتاز">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Product Name (EN)</label>
                <input id="pm_name_en" class="form-control" placeholder="Example: Extra Virgin Olive Oil">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">اختيار الفئة</label>
                <select id="pm_category_select" class="form-select">
                  <option value="">اختر فئة</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">صورة المنتج</label>
                <input id="pm_image_input" class="form-control" type="file" accept="image/*">
                <img id="pm_image_preview" src="" class="product-modal-image-preview mt-2 d-none" alt="product-image-preview">
                <div id="pm_image_hint" class="small text-muted mt-1">يمكنك تغيير الصورة من هنا.</div>
              </div>
            </div>
          </div>
        </div>
        <div class="card border-0 bg-light-subtle">
          <div class="card-body">
            <h6 class="mb-3 text-success">الوصف والمميزات</h6>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">الوصف (عربي)</label>
                <textarea id="pm_description_ar" class="form-control" rows="3" placeholder="أدخل وصفًا موجزًا للمنتج"></textarea>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Description (EN)</label>
                <textarea id="pm_description_en" class="form-control" rows="3" placeholder="Add a short product description"></textarea>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">المميزات (عربي) - كل ميزة بسطر</label>
                <textarea id="pm_features_ar" class="form-control" rows="4" placeholder="ميزة 1&#10;ميزة 2"></textarea>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Features (EN) - one per line</label>
                <textarea id="pm_features_en" class="form-control" rows="4" placeholder="Feature 1&#10;Feature 2"></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer d-flex justify-content-between">
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
          <button type="button" class="btn btn-primary" id="pm_save_btn" data-loading-text="جاري الحفظ..."><i class="bi bi-check2"></i> حفظ</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="categoriesModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="categoriesModalTitle">إضافة فئة</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="row g-2">
          <div class="col-12">
            <label class="form-label">الفئة عربي</label>
            <input id="categoryArInput" class="form-control" placeholder="مثال: زيتون أخضر">
          </div>
          <div class="col-12">
            <label class="form-label">Category EN</label>
            <input id="categoryEnInput" class="form-control" placeholder="Example: Green Olives">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-success" id="saveCategoryBtn" data-loading-text="جاري الحفظ...">
          <i class="bi bi-check2"></i> حفظ
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="duplicateProductModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">تأكيد الاستنساخ</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        هل تريد استنساخ هذا المنتج؟
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-primary" id="confirmDuplicateProductBtn">
          <i class="bi bi-files"></i> استنساخ
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="confirmDeleteTitle">تأكيد الحذف</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="confirmDeleteMessage">
        هل أنت متأكد من عملية الحذف؟
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
          <i class="bi bi-trash"></i> حذف
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade product-image-preview-modal" id="productImagePreviewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">معاينة صورة المنتج</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <img id="productImagePreviewTarget" src="" alt="product-preview">
      </div>
      <div class="modal-footer d-flex justify-content-end gap-2">
        <a id="productImageDownloadBtn" class="btn btn-outline-primary" href="#" download>
          <i class="bi bi-download"></i> تحميل الصورة
        </a>
        <button type="button" id="productImageCopyLinkBtn" class="btn btn-outline-secondary">
          <i class="bi bi-link-45deg"></i> نسخ رابط الصورة
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(() => {
  const appBaseUrl = <%- JSON.stringify(baseUrl || '') %>;
  const addRow = (container, html) => container.insertAdjacentHTML('beforeend', html);
  const placeholderSvg = `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="90" height="90"><rect width="100%" height="100%" fill="#f1f3f5"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#777777" font-size="12">No Image</text></svg>')}`;
  const siteTabsElement = document.getElementById('siteTabs');
  const productsAccordionElement = document.getElementById('productsSectionsAccordion');
  const tabsStorageKey = 'siteManagementActiveTab';
  const productsUiStateStorageKey = 'siteManagementProductsUiState';
  const productEditorModalElement = document.getElementById('productEditorModal');
  const productEditorModal = productEditorModalElement ? new bootstrap.Modal(productEditorModalElement) : null;
  const productEditorTitle = productEditorModalElement?.querySelector('.modal-title');
  const productEditorDeleteBtn = document.getElementById('pm_delete_btn');
  const pmImageInput = document.getElementById('pm_image_input');
  const pmImagePreview = document.getElementById('pm_image_preview');
  const pmImageHint = document.getElementById('pm_image_hint');
  const pmCategorySelect = document.getElementById('pm_category_select');
  const categoriesModalElement = document.getElementById('categoriesModal');
  const categoriesModal = categoriesModalElement ? new bootstrap.Modal(categoriesModalElement) : null;
  const duplicateProductModalElement = document.getElementById('duplicateProductModal');
  const duplicateProductModal = duplicateProductModalElement ? new bootstrap.Modal(duplicateProductModalElement) : null;
  const confirmDuplicateProductBtn = document.getElementById('confirmDuplicateProductBtn');
  const confirmDeleteModalElement = document.getElementById('confirmDeleteModal');
  const confirmDeleteModal = confirmDeleteModalElement ? new bootstrap.Modal(confirmDeleteModalElement) : null;
  const productImagePreviewModalElement = document.getElementById('productImagePreviewModal');
  const productImagePreviewModal = productImagePreviewModalElement ? new bootstrap.Modal(productImagePreviewModalElement) : null;
  const productImagePreviewTarget = document.getElementById('productImagePreviewTarget');
  const productImageDownloadBtn = document.getElementById('productImageDownloadBtn');
  const productImageCopyLinkBtn = document.getElementById('productImageCopyLinkBtn');
  const confirmDeleteTitle = document.getElementById('confirmDeleteTitle');
  const confirmDeleteMessage = document.getElementById('confirmDeleteMessage');
  const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
  const categoriesModalTitle = document.getElementById('categoriesModalTitle');
  const categoryArInput = document.getElementById('categoryArInput');
  const categoryEnInput = document.getElementById('categoryEnInput');
  const saveCategoryBtn = document.getElementById('saveCategoryBtn');
  const siteManagementForm = document.getElementById('siteManagementForm');
  const deleteInboxMessageForm = document.getElementById('deleteInboxMessageForm');
  let activeProductCard = null;
  let activeDraggedProductRow = null;
  let pendingDuplicateProductCard = null;
  let pendingDeleteAction = null;
  let pendingNewSectionKey = null;
  let activeProductSectionKey = null;
  let activeCategorySectionKey = null;
  let activeCategoryIndex = null;
  let formSubmitInProgress = false;

  function getProductsUiState() {
    try {
      const raw = localStorage.getItem(productsUiStateStorageKey);
      if (!raw) return { openCollapseId: '', scrollY: 0 };
      const parsed = JSON.parse(raw);
      return {
        openCollapseId: typeof parsed?.openCollapseId === 'string' ? parsed.openCollapseId : '',
        scrollY: Number.isFinite(parsed?.scrollY) ? parsed.scrollY : 0
      };
    } catch (_) {
      return { openCollapseId: '', scrollY: 0 };
    }
  }

  function saveProductsUiState(partial = {}) {
    try {
      const current = getProductsUiState();
      const next = {
        ...current,
        ...partial
      };
      localStorage.setItem(productsUiStateStorageKey, JSON.stringify(next));
    } catch (_) {}
  }

  function getActiveTabTarget() {
    return siteTabsElement?.querySelector('.nav-link.active')?.getAttribute('data-bs-target') || '';
  }

  function restoreProductsUiState() {
    const state = getProductsUiState();
    if (state.openCollapseId) {
      const collapseEl = document.querySelector(state.openCollapseId);
      if (collapseEl) {
        bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false }).show();
      }
    }

    if (Number.isFinite(state.scrollY) && state.scrollY > 0) {
      setTimeout(() => {
        window.scrollTo({ top: state.scrollY, behavior: 'auto' });
      }, 140);
    }
  }

  function updateSaveButtonVisibility() {
    // تم إلغاء زر الحفظ اليدوي، وأصبحت الصفحة تعتمد على الحفظ الفوري.
  }

  function submitSiteManagementForm() {
    if (formSubmitInProgress || !siteManagementForm) return;
    formSubmitInProgress = true;
    siteManagementForm.requestSubmit();
  }

  function field(card, key) {
    return card.querySelector(`[data-field="${key}"]`);
  }

  function readField(card, key) {
    const input = field(card, key);
    return input ? input.value : '';
  }

  function writeField(card, key, value) {
    const input = field(card, key);
    if (input) input.value = value || '';
  }

  function updateProductCardSummary(card) {
    const nameAr = readField(card, 'name_ar') || 'منتج بدون اسم';
    const nameEn = readField(card, 'name_en') || '-';
    const categoryAr = readField(card, 'category_ar') || '-';
    const descriptionAr = readField(card, 'description_ar') || '-';
    const descriptionEn = readField(card, 'description_en') || '-';
    const featuresAr = readField(card, 'features_ar') || '-';
    const featuresEn = readField(card, 'features_en') || '-';
    const image = readField(card, 'current_image') || placeholderSvg;

    const nameArEl = card.querySelector('.js-name-ar');
    const nameEnEl = card.querySelector('.js-name-en');
    const catArEl = card.querySelector('.js-category-ar');
    const descArEl = card.querySelector('.js-description-ar');
    const descEnEl = card.querySelector('.js-description-en');
    const featuresArEl = card.querySelector('.js-features-ar');
    const featuresEnEl = card.querySelector('.js-features-en');
    const imgEl = card.querySelector('.js-card-image');

    if (nameArEl) nameArEl.textContent = nameAr;
    if (nameEnEl) nameEnEl.textContent = nameEn;
    if (catArEl) catArEl.textContent = categoryAr;
    if (descArEl) descArEl.textContent = descriptionAr;
    if (descEnEl) descEnEl.textContent = descriptionEn;
    if (featuresArEl) featuresArEl.textContent = featuresAr;
    if (featuresEnEl) featuresEnEl.textContent = featuresEn;
    if (imgEl) imgEl.src = image;
  }

  function getSelectedProductCategory() {
    if (!pmCategorySelect) return { ar: '', en: '' };
    const selectedOption = pmCategorySelect.options[pmCategorySelect.selectedIndex];
    const ar = selectedOption?.dataset?.ar || '';
    const en = selectedOption?.dataset?.en || '';
    return { ar, en };
  }

  function populateProductCategoryOptions(sectionKey, currentAr = '', currentEn = '') {
    if (!pmCategorySelect) return;
    const rows = readSectionCategories(sectionKey);
    const currentPair = `${currentAr}|||${currentEn}`;
    const values = rows.map((x) => `${x.ar || ''}|||${x.en || ''}`);
    const hasCurrent = currentAr || currentEn ? values.includes(currentPair) : true;
    const normalizedRows = hasCurrent ? rows : [...rows, { ar: currentAr, en: currentEn }];

    pmCategorySelect.innerHTML = '<option value="">اختر فئة</option>';
    normalizedRows.forEach((row) => {
      const option = document.createElement('option');
      option.value = `${row.ar || ''}|||${row.en || ''}`;
      option.dataset.ar = row.ar || '';
      option.dataset.en = row.en || '';
      option.textContent = `${row.ar || '-'} / ${row.en || '-'}`;
      pmCategorySelect.appendChild(option);
    });

    if (currentAr || currentEn) {
      pmCategorySelect.value = `${currentAr || ''}|||${currentEn || ''}`;
    } else if (normalizedRows.length) {
      pmCategorySelect.selectedIndex = 1;
    } else {
      pmCategorySelect.selectedIndex = 0;
    }

  }

  function openProductEditor(card) {
    if (!productEditorModal) return;
    activeProductCard = card;
    pendingNewSectionKey = null;
    activeProductSectionKey = card.dataset.section || null;
    if (productEditorTitle) productEditorTitle.textContent = 'تعديل المنتج';
    if (productEditorDeleteBtn) productEditorDeleteBtn.classList.remove('d-none');

    document.getElementById('pm_name_ar').value = readField(card, 'name_ar');
    document.getElementById('pm_name_en').value = readField(card, 'name_en');
    const currentCategoryAr = readField(card, 'category_ar');
    const currentCategoryEn = readField(card, 'category_en');
    populateProductCategoryOptions(activeProductSectionKey, currentCategoryAr, currentCategoryEn);
    document.getElementById('pm_description_ar').value = readField(card, 'description_ar');
    document.getElementById('pm_description_en').value = readField(card, 'description_en');
    document.getElementById('pm_features_ar').value = readField(card, 'features_ar');
    document.getElementById('pm_features_en').value = readField(card, 'features_en');
    if (pmImageInput) pmImageInput.value = '';
    const currentImage = readField(card, 'current_image');
    if (pmImagePreview) {
      if (currentImage) {
        pmImagePreview.src = currentImage;
        pmImagePreview.classList.remove('d-none');
        if (pmImageHint) pmImageHint.classList.add('d-none');
      } else {
        pmImagePreview.removeAttribute('src');
        pmImagePreview.classList.add('d-none');
        if (pmImageHint) pmImageHint.classList.remove('d-none');
      }
    }

    productEditorModal.show();
  }

  function openCreateProductModal(sectionKey) {
    if (!productEditorModal) return;
    activeProductCard = null;
    pendingNewSectionKey = sectionKey;
    activeProductSectionKey = sectionKey;
    if (productEditorTitle) productEditorTitle.textContent = 'إضافة منتج جديد';
    if (productEditorDeleteBtn) productEditorDeleteBtn.classList.add('d-none');

    document.getElementById('pm_name_ar').value = '';
    document.getElementById('pm_name_en').value = '';
    populateProductCategoryOptions(sectionKey, '', '');
    document.getElementById('pm_description_ar').value = '';
    document.getElementById('pm_description_en').value = '';
    document.getElementById('pm_features_ar').value = '';
    document.getElementById('pm_features_en').value = '';
    if (pmImageInput) pmImageInput.value = '';
    if (pmImagePreview) {
      pmImagePreview.removeAttribute('src');
      pmImagePreview.classList.add('d-none');
    }
    if (pmImageHint) pmImageHint.classList.remove('d-none');

    productEditorModal.show();
  }

  function createProductCardFromValues(sectionKey, values) {
    const container = document.getElementById(`${sectionKey}_products_container`);
    if (!container) return null;
    const html = `<tr class="product-row" data-section="${sectionKey}" draggable="false"><td><button type="button" class="btn btn-sm btn-light border drag-handle-btn" title="سحب لإعادة الترتيب" aria-label="سحب لإعادة الترتيب"><i class="bi bi-grip-vertical"></i></button></td><td><img class="product-thumb js-card-image" src="${placeholderSvg}" alt="product-image"></td><td class="js-name-ar">منتج جديد</td><td class="js-name-en">-</td><td class="js-category-ar">-</td><td class="js-description-ar product-long-cell">-</td><td class="js-description-en product-long-cell">-</td><td class="js-features-ar product-long-cell">-</td><td class="js-features-en product-long-cell">-</td><td><div class="d-flex gap-1"><button type="button" class="btn btn-sm btn-outline-primary js-edit-product" title="تعديل المنتج" aria-label="تعديل المنتج"><i class="bi bi-pencil-square"></i></button><button type="button" class="btn btn-sm btn-outline-secondary duplicate-product-btn" title="استنساخ المنتج" aria-label="استنساخ المنتج"><i class="bi bi-files"></i></button><button type="button" class="btn btn-sm btn-outline-danger product-delete-btn" title="حذف المنتج" aria-label="حذف المنتج"><i class="bi bi-trash"></i></button></div><input type="hidden" data-field="id" name="${sectionKey}_product_id" value=""><input type="hidden" data-field="category_ar" name="${sectionKey}_product_category_ar" value=""><input type="hidden" data-field="category_en" name="${sectionKey}_product_category_en" value=""><input type="hidden" data-field="name_ar" name="${sectionKey}_product_name_ar" value=""><input type="hidden" data-field="name_en" name="${sectionKey}_product_name_en" value=""><textarea class="d-none" data-field="description_ar" name="${sectionKey}_product_description_ar"></textarea><textarea class="d-none" data-field="description_en" name="${sectionKey}_product_description_en"></textarea><textarea class="d-none" data-field="features_ar" name="${sectionKey}_product_features_ar"></textarea><textarea class="d-none" data-field="features_en" name="${sectionKey}_product_features_en"></textarea><input class="d-none section-product-image-input" type="file" accept="image/*"><input type="hidden" data-field="current_image" name="${sectionKey}_current_product_image" value=""></td></tr>`;
    addRow(container, html);
    const newCard = container.querySelector('tr.product-row:last-child');
    if (!newCard) return null;

    if (typeof values.id !== 'undefined') {
      writeField(newCard, 'id', values.id);
    }
    writeField(newCard, 'name_ar', values.name_ar);
    writeField(newCard, 'name_en', values.name_en);
    writeField(newCard, 'category_ar', values.category_ar);
    writeField(newCard, 'category_en', values.category_en);
    writeField(newCard, 'description_ar', values.description_ar);
    writeField(newCard, 'description_en', values.description_en);
    writeField(newCard, 'features_ar', values.features_ar);
    writeField(newCard, 'features_en', values.features_en);
    updateProductCardSummary(newCard);
    reindexProductFiles(sectionKey);
    return newCard;
  }

  function saveProductEditor() {
    const saveBtn = document.getElementById('pm_save_btn');
    if (saveBtn?.disabled) return;
    window.modalSubmitUi?.setLoading(saveBtn, saveBtn?.getAttribute('data-loading-text'));

    let selectedCategory = { ar: '', en: '' };
    if (pmCategorySelect) {
      if (pmCategorySelect.options.length <= 1) {
        window.modalSubmitUi?.resetLoading(saveBtn);
        alert('لا توجد فئات في هذا القسم. أضف فئة أولاً.');
        return;
      }
      if (pmCategorySelect.selectedIndex <= 0) {
        window.modalSubmitUi?.resetLoading(saveBtn);
        alert('يرجى اختيار فئة للمنتج.');
        return;
      }
      selectedCategory = getSelectedProductCategory();
    }

    const values = {
      name_ar: document.getElementById('pm_name_ar').value,
      name_en: document.getElementById('pm_name_en').value,
      category_ar: selectedCategory.ar,
      category_en: selectedCategory.en,
      description_ar: document.getElementById('pm_description_ar').value,
      description_en: document.getElementById('pm_description_en').value,
      features_ar: document.getElementById('pm_features_ar').value,
      features_en: document.getElementById('pm_features_en').value
    };

    if (activeProductCard) {
      writeField(activeProductCard, 'name_ar', values.name_ar);
      writeField(activeProductCard, 'name_en', values.name_en);
      writeField(activeProductCard, 'category_ar', values.category_ar);
      writeField(activeProductCard, 'category_en', values.category_en);
      writeField(activeProductCard, 'description_ar', values.description_ar);
      writeField(activeProductCard, 'description_en', values.description_en);
      writeField(activeProductCard, 'features_ar', values.features_ar);
      writeField(activeProductCard, 'features_en', values.features_en);
      if (pmImageInput?.files?.[0]) {
        const rowImageInput = activeProductCard.querySelector('.section-product-image-input');
        if (rowImageInput) {
          const dt = new DataTransfer();
          dt.items.add(pmImageInput.files[0]);
          rowImageInput.files = dt.files;
        }
        const objectUrl = URL.createObjectURL(pmImageInput.files[0]);
        writeField(activeProductCard, 'current_image', objectUrl);
      }
      updateProductCardSummary(activeProductCard);
    } else if (pendingNewSectionKey) {
      const newCard = createProductCardFromValues(pendingNewSectionKey, values);
      if (newCard && pmImageInput?.files?.[0]) {
        const rowImageInput = newCard.querySelector('.section-product-image-input');
        if (rowImageInput) {
          const dt = new DataTransfer();
          dt.items.add(pmImageInput.files[0]);
          rowImageInput.files = dt.files;
        }
        const objectUrl = URL.createObjectURL(pmImageInput.files[0]);
        writeField(newCard, 'current_image', objectUrl);
        updateProductCardSummary(newCard);
      }
    }

    updateSaveButtonVisibility();
    productEditorModal.hide();
    submitSiteManagementForm();
  }

  function deleteActiveProduct() {
    if (!activeProductCard) return;
    const sectionKey = activeProductCard.dataset.section;
    activeProductCard.remove();
    if (sectionKey) reindexProductFiles(sectionKey);
    updateSaveButtonVisibility();
    productEditorModal.hide();
    activeProductCard = null;
  }

  function requestDelete(options) {
    pendingDeleteAction = typeof options?.onConfirm === 'function' ? options.onConfirm : null;
    if (confirmDeleteTitle) confirmDeleteTitle.textContent = options?.title || 'تأكيد الحذف';
    if (confirmDeleteMessage) confirmDeleteMessage.textContent = options?.message || 'هل أنت متأكد من عملية الحذف؟';
    confirmDeleteModal?.show();
  }

  function reindexProductFiles(sectionKey) {
    const container = document.getElementById(`${sectionKey}_products_container`);
    if (!container) return;
    container.querySelectorAll('.section-product-image-input').forEach((input, idx) => {
      input.name = `${sectionKey}_product_image_${idx}`;
    });
  }

  function nextProductIdForSection(sectionKey) {
    const container = document.getElementById(`${sectionKey}_products_container`);
    if (!container) return '';
    const ids = Array.from(container.querySelectorAll('.product-row'))
      .map((row) => Number(readField(row, 'id')))
      .filter((n) => Number.isFinite(n) && n > 0);
    if (!ids.length) return '';
    return String(Math.max(...ids) + 1);
  }

  function duplicateProductRow(sourceRow) {
    const sectionKey = sourceRow?.dataset?.section;
    if (!sectionKey) return;
    const values = {
      id: nextProductIdForSection(sectionKey),
      name_ar: readField(sourceRow, 'name_ar'),
      name_en: readField(sourceRow, 'name_en'),
      category_ar: readField(sourceRow, 'category_ar'),
      category_en: readField(sourceRow, 'category_en'),
      description_ar: readField(sourceRow, 'description_ar'),
      description_en: readField(sourceRow, 'description_en'),
      features_ar: readField(sourceRow, 'features_ar'),
      features_en: readField(sourceRow, 'features_en')
    };
    const newRow = createProductCardFromValues(sectionKey, values);
    if (newRow) {
      writeField(newRow, 'current_image', readField(sourceRow, 'current_image'));
      updateProductCardSummary(newRow);
      updateSaveButtonVisibility();
    }
  }

  function requestDuplicateProduct(row) {
    if (!row) return;
    if (!duplicateProductModal || !confirmDuplicateProductBtn) {
      duplicateProductRow(row);
      return;
    }
    pendingDuplicateProductCard = row;
    duplicateProductModal.show();
  }

  function finalizeProductRowDrag() {
    if (!activeDraggedProductRow) return;
    const sectionKey = activeDraggedProductRow.dataset.section;
    activeDraggedProductRow.classList.remove('product-row-dragging');
    activeDraggedProductRow.setAttribute('draggable', 'false');
    activeDraggedProductRow = null;
    if (sectionKey) reindexProductFiles(sectionKey);
    submitSiteManagementForm();
  }

  function setupProductRowDnD(container) {
    if (!container || container.dataset.dndReady === '1') return;
    container.dataset.dndReady = '1';

    container.addEventListener('dragstart', (event) => {
      const row = event.target.closest('.product-row');
      if (!row || row.getAttribute('draggable') !== 'true') {
        event.preventDefault();
        return;
      }
      activeDraggedProductRow = row;
      row.classList.add('product-row-dragging');
      if (event.dataTransfer) {
        event.dataTransfer.effectAllowed = 'move';
        event.dataTransfer.setData('text/plain', row.dataset.section || 'product-row');
      }
    });

    container.addEventListener('dragover', (event) => {
      if (!activeDraggedProductRow) return;
      event.preventDefault();
      const targetRow = event.target.closest('.product-row');
      if (!targetRow || targetRow === activeDraggedProductRow) return;
      const rect = targetRow.getBoundingClientRect();
      const shouldInsertAfter = event.clientY > rect.top + rect.height / 2;
      if (shouldInsertAfter) {
        targetRow.parentNode.insertBefore(activeDraggedProductRow, targetRow.nextSibling);
      } else {
        targetRow.parentNode.insertBefore(activeDraggedProductRow, targetRow);
      }
    });

    container.addEventListener('drop', (event) => {
      if (!activeDraggedProductRow) return;
      event.preventDefault();
      finalizeProductRowDrag();
    });

    container.addEventListener('dragend', () => {
      finalizeProductRowDrag();
    });
  }

  function openProductImagePreview(src, altText = 'product-image') {
    if (!productImagePreviewModal || !productImagePreviewTarget || !src) return;
    productImagePreviewTarget.src = src;
    productImagePreviewTarget.alt = altText || 'product-image';
    if (productImageDownloadBtn) {
      productImageDownloadBtn.href = src;
      productImageDownloadBtn.setAttribute('download', `image-${Date.now()}`);
    }
    productImagePreviewModal.show();
  }

  function toAbsoluteImageUrl(value) {
    const raw = String(value || '').trim();
    if (!raw) return '';
    if (/^https?:\/\//i.test(raw) || raw.startsWith('data:') || raw.startsWith('blob:')) return raw;
    if (!appBaseUrl) return raw;
    if (raw.startsWith('/')) return `${appBaseUrl.replace(/\/+$/, '')}${raw}`;
    return `${appBaseUrl.replace(/\/+$/, '')}/${raw}`;
  }

  productImageCopyLinkBtn?.addEventListener('click', async () => {
    const imageUrl = toAbsoluteImageUrl(productImagePreviewTarget?.getAttribute('src') || '');
    if (!imageUrl) return;
    try {
      await navigator.clipboard.writeText(imageUrl);
      alert('تم نسخ رابط الصورة');
    } catch (_) {
      const tempInput = document.createElement('input');
      tempInput.value = imageUrl;
      document.body.appendChild(tempInput);
      tempInput.select();
      document.execCommand('copy');
      document.body.removeChild(tempInput);
      alert('تم نسخ رابط الصورة');
    }
  });

  productImagePreviewModalElement?.addEventListener('hidden.bs.modal', () => {
    if (!productImagePreviewTarget) return;
    productImagePreviewTarget.removeAttribute('src');
    if (productImageDownloadBtn) productImageDownloadBtn.setAttribute('href', '#');
  });

  function activateTabByTarget(target) {
    if (!siteTabsElement || !target) return;
    const tabBtn = siteTabsElement.querySelector(`[data-bs-target="${target}"]`);
    if (!tabBtn) return;
    bootstrap.Tab.getOrCreateInstance(tabBtn).show();
  }

  function splitLines(value) {
    return String(value || '')
      .split(/\r?\n/)
      .map((x) => x.trim())
      .filter(Boolean);
  }

  function categoriesStorage(sectionKey) {
    return {
      ar: document.querySelector(`.categories-ar-storage[data-section="${sectionKey}"]`),
      en: document.querySelector(`.categories-en-storage[data-section="${sectionKey}"]`)
    };
  }

  function readSectionCategories(sectionKey) {
    const storage = categoriesStorage(sectionKey);
    const arRows = splitLines(storage.ar?.value || '');
    const enRows = splitLines(storage.en?.value || '');
    const max = Math.max(arRows.length, enRows.length);
    const rows = [];
    for (let i = 0; i < max; i += 1) {
      const ar = arRows[i] || '';
      const en = enRows[i] || '';
      if (!ar && !en) continue;
      rows.push({ ar, en });
    }
    return rows;
  }

  function writeSectionCategories(sectionKey, rows) {
    const storage = categoriesStorage(sectionKey);
    if (!storage.ar || !storage.en) return;
    storage.ar.value = rows.map((x) => x.ar || '').join('\n');
    storage.en.value = rows.map((x) => x.en || '').join('\n');
  }

  function renderCategoriesPreview(sectionKey) {
    const preview = document.getElementById(`${sectionKey}_categories_list`);
    const pill = document.querySelector(`.js-category-count-pill[data-section="${sectionKey}"]`);
    if (!preview) return;
    const rows = readSectionCategories(sectionKey);
    if (!rows.length) {
      preview.innerHTML = '<span class="text-muted small">لا توجد فئات مضافة بعد.</span>';
      if (pill) pill.textContent = 'عدد الفئات: 0';
      return;
    }
    preview.innerHTML = rows
      .map((row, idx) => `
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 border rounded px-2 py-1 bg-white">
          <span class="category-chip mb-0">${row.ar || '-'} / ${row.en || '-'}</span>
          <div class="d-flex gap-1">
            <button type="button" class="btn btn-sm btn-outline-primary edit-category-btn" data-section="${sectionKey}" data-index="${idx}" title="تعديل الفئة" aria-label="تعديل الفئة">
              <i class="bi bi-pencil-square"></i>
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger delete-category-btn" data-section="${sectionKey}" data-index="${idx}" title="حذف الفئة" aria-label="حذف الفئة">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
      `)
      .join('');
    if (pill) pill.textContent = `عدد الفئات: ${rows.length}`;
  }

  function initSiteImagePreview(inputId, imageId, hintId) {
    const input = document.getElementById(inputId);
    const img = document.getElementById(imageId);
    const hint = document.getElementById(hintId);
    if (!input || !img) return;

    let objectUrl = null;

    const resetToExisting = () => {
      if (objectUrl) {
        URL.revokeObjectURL(objectUrl);
        objectUrl = null;
      }
      const existingSrc = img.getAttribute('data-existing-src') || '';
      if (existingSrc) {
        img.src = existingSrc;
        img.classList.remove('d-none');
        if (hint) hint.classList.add('d-none');
      } else {
        img.removeAttribute('src');
        img.classList.add('d-none');
        if (hint) hint.classList.remove('d-none');
      }
    };

    input.addEventListener('change', () => {
      const [file] = input.files || [];
      if (!file) {
        resetToExisting();
        return;
      }

      if (objectUrl) URL.revokeObjectURL(objectUrl);
      objectUrl = URL.createObjectURL(file);
      img.src = objectUrl;
      img.classList.remove('d-none');
      if (hint) hint.classList.add('d-none');
      submitSiteManagementForm();
    });

    window.addEventListener('beforeunload', () => {
      if (objectUrl) URL.revokeObjectURL(objectUrl);
    });
  }

  function openCategoriesModal(sectionKey, sectionLabel, index = null) {
    if (!categoriesModal) return;
    activeCategorySectionKey = sectionKey;
    activeCategoryIndex = Number.isInteger(index) ? index : null;
    const rows = readSectionCategories(sectionKey);
    if (activeCategoryIndex === null) {
      if (categoriesModalTitle) categoriesModalTitle.textContent = `إضافة فئة - ${sectionLabel}`;
      if (categoryArInput) categoryArInput.value = '';
      if (categoryEnInput) categoryEnInput.value = '';
    } else {
      if (categoriesModalTitle) categoriesModalTitle.textContent = `تعديل فئة - ${sectionLabel}`;
      const current = rows[activeCategoryIndex] || { ar: '', en: '' };
      if (categoryArInput) categoryArInput.value = current.ar || '';
      if (categoryEnInput) categoryEnInput.value = current.en || '';
    }
    categoriesModal.show();
  }

  function saveCategoriesModal() {
    const saveBtn = document.getElementById('saveCategoryBtn');
    if (saveBtn?.disabled) return;
    window.modalSubmitUi?.setLoading(saveBtn, saveBtn?.getAttribute('data-loading-text'));

    if (!activeCategorySectionKey) {
      window.modalSubmitUi?.resetLoading(saveBtn);
      return;
    }
    const ar = categoryArInput?.value?.trim() || '';
    const en = categoryEnInput?.value?.trim() || '';
    if (!ar && !en) {
      window.modalSubmitUi?.resetLoading(saveBtn);
      return;
    }

    const rows = readSectionCategories(activeCategorySectionKey);
    if (activeCategoryIndex === null) {
      rows.push({ ar, en });
    } else if (rows[activeCategoryIndex]) {
      rows[activeCategoryIndex] = { ar, en };
    }

    writeSectionCategories(activeCategorySectionKey, rows);
    renderCategoriesPreview(activeCategorySectionKey);
    if (activeProductSectionKey && activeProductSectionKey === activeCategorySectionKey) {
      const currentCategory = getSelectedProductCategory();
      const currentAr = currentCategory.ar;
      const currentEn = currentCategory.en;
      populateProductCategoryOptions(activeProductSectionKey, currentAr, currentEn);
    }
    updateSaveButtonVisibility();
    categoriesModal.hide();
    submitSiteManagementForm();
  }

  document.querySelectorAll('.add-product-btn').forEach((btn) => {
    btn.addEventListener('click', () => openCreateProductModal(btn.dataset.section));
  });
  document.querySelectorAll('.add-category-btn').forEach((btn) => {
    btn.addEventListener('click', () => openCategoriesModal(btn.dataset.section, btn.dataset.label || '', null));
  });

  document.getElementById('pm_save_btn')?.addEventListener('click', saveProductEditor);
  document.getElementById('pm_delete_btn')?.addEventListener('click', () => {
    if (!activeProductCard) return;
    requestDelete({
      title: 'تأكيد حذف المنتج',
      message: 'هل تريد حذف هذا المنتج؟',
      onConfirm: () => deleteActiveProduct()
    });
  });
  saveCategoryBtn?.addEventListener('click', saveCategoriesModal);
  confirmDuplicateProductBtn?.addEventListener('click', () => {
    if (pendingDuplicateProductCard) {
      duplicateProductRow(pendingDuplicateProductCard);
    }
    pendingDuplicateProductCard = null;
    duplicateProductModal?.hide();
    submitSiteManagementForm();
  });
  confirmDeleteBtn?.addEventListener('click', () => {
    if (pendingDeleteAction) pendingDeleteAction();
    pendingDeleteAction = null;
    confirmDeleteModal?.hide();
  });
  pmCategorySelect?.addEventListener('change', () => {
    updateSaveButtonVisibility();
  });

  pmImageInput?.addEventListener('change', () => {
    const file = pmImageInput.files?.[0];
    if (!pmImagePreview) return;
    if (!file) {
      pmImagePreview.removeAttribute('src');
      pmImagePreview.classList.add('d-none');
      if (pmImageHint) pmImageHint.classList.remove('d-none');
      return;
    }
    const objectUrl = URL.createObjectURL(file);
    pmImagePreview.src = objectUrl;
    pmImagePreview.classList.remove('d-none');
    if (pmImageHint) pmImageHint.classList.add('d-none');
  });

  document.addEventListener('click', (e) => {
    const imageEl = e.target.closest('.js-card-image');
    if (imageEl) {
      openProductImagePreview(imageEl.getAttribute('src') || '', imageEl.getAttribute('alt') || 'product-image');
      return;
    }

    const inboxImageLink = e.target.closest('.js-inbox-attachment-link');
    if (inboxImageLink) {
      e.preventDefault();
      openProductImagePreview(
        inboxImageLink.getAttribute('data-image-url') || inboxImageLink.getAttribute('href') || '',
        inboxImageLink.getAttribute('data-image-alt') || 'attachment'
      );
      return;
    }

    const editBtn = e.target.closest('.js-edit-product');
    if (editBtn) {
      const row = editBtn.closest('.product-row');
      if (row) openProductEditor(row);
      return;
    }

    const productDeleteBtn = e.target.closest('.product-delete-btn');
    if (productDeleteBtn) {
      const row = productDeleteBtn.closest('.product-row');
      const sectionKey = row?.dataset?.section;
      if (!row) return;
      requestDelete({
        title: 'تأكيد حذف المنتج',
        message: 'هل تريد حذف هذا المنتج؟',
        onConfirm: () => {
          row.remove();
          if (sectionKey) reindexProductFiles(sectionKey);
          updateSaveButtonVisibility();
          submitSiteManagementForm();
        }
      });
      return;
    }

    const duplicateProductBtn = e.target.closest('.duplicate-product-btn');
    if (duplicateProductBtn) {
      const row = duplicateProductBtn.closest('.product-row');
      if (!row) return;
      requestDuplicateProduct(row);
      return;
    }

    const deleteInboxMessageBtn = e.target.closest('.delete-inbox-message-btn');
    if (deleteInboxMessageBtn) {
      const messageId = Number(deleteInboxMessageBtn.dataset.messageId);
      if (!Number.isFinite(messageId) || messageId <= 0 || !deleteInboxMessageForm) return;
      requestDelete({
        title: 'تأكيد حذف الرسالة',
        message: 'هل تريد حذف هذه الرسالة من البريد الوارد؟',
        onConfirm: () => {
          deleteInboxMessageForm.action = `/site-management/contact-messages/${messageId}/delete`;
          deleteInboxMessageForm.submit();
        }
      });
      return;
    }

    const removeBtn = e.target.closest('.remove-row-btn');
    if (removeBtn) {
      const row = removeBtn.closest('.footer-counter-row');
      if (row) row.remove();
      return;
    }

    const editCategoryBtn = e.target.closest('.edit-category-btn');
    if (editCategoryBtn) {
      const sectionKey = editCategoryBtn.dataset.section;
      const sectionLabel = document.querySelector(`.add-category-btn[data-section="${sectionKey}"]`)?.dataset?.label || '';
      const index = Number(editCategoryBtn.dataset.index);
      if (sectionKey && Number.isFinite(index)) openCategoriesModal(sectionKey, sectionLabel, index);
      return;
    }

    const deleteCategoryBtn = e.target.closest('.delete-category-btn');
    if (!deleteCategoryBtn) return;
    const sectionKey = deleteCategoryBtn.dataset.section;
    const index = Number(deleteCategoryBtn.dataset.index);
    if (!sectionKey || !Number.isFinite(index)) return;
    requestDelete({
      title: 'تأكيد حذف الفئة',
      message: 'هل تريد حذف هذه الفئة؟',
      onConfirm: () => {
        const rows = readSectionCategories(sectionKey);
        if (!rows[index]) return;
        rows.splice(index, 1);
        writeSectionCategories(sectionKey, rows);
        renderCategoriesPreview(sectionKey);
        updateSaveButtonVisibility();
        submitSiteManagementForm();
      }
    });
  });

  document.addEventListener('mousedown', (event) => {
    const handleBtn = event.target.closest('.drag-handle-btn');
    if (!handleBtn) return;
    const row = handleBtn.closest('.product-row');
    if (!row) return;
    row.setAttribute('draggable', 'true');
  });

  document.addEventListener('mouseup', () => {
    if (activeDraggedProductRow) return;
    document.querySelectorAll('.product-row[draggable="true"]').forEach((row) => {
      row.setAttribute('draggable', 'false');
    });
  });

  document.querySelectorAll('.product-row').forEach(updateProductCardSummary);
  ['olive_products', 'olive_oil', 'agri_crops'].forEach(reindexProductFiles);
  ['olive_products', 'olive_oil', 'agri_crops'].forEach((sectionKey) => {
    setupProductRowDnD(document.getElementById(`${sectionKey}_products_container`));
  });
  ['olive_products', 'olive_oil', 'agri_crops'].forEach(renderCategoriesPreview);
  initSiteImagePreview('logoImageInput', 'logoPreviewImage', 'logoPreviewHint');
  initSiteImagePreview('iconImageInput', 'iconPreviewImage', 'iconPreviewHint');

  productsAccordionElement?.querySelectorAll('.accordion-collapse').forEach((collapseEl) => {
    collapseEl.addEventListener('shown.bs.collapse', (event) => {
      const openCollapseId = event.target?.id ? `#${event.target.id}` : '';
      saveProductsUiState({ openCollapseId, scrollY: window.scrollY });
    });
    collapseEl.addEventListener('hidden.bs.collapse', (event) => {
      const openCollapseId = event.target?.id ? `#${event.target.id}` : '';
      const state = getProductsUiState();
      if (state.openCollapseId === openCollapseId) {
        saveProductsUiState({ openCollapseId: '', scrollY: window.scrollY });
      }
    });
  });

  window.addEventListener('scroll', () => {
    if (getActiveTabTarget() !== '#tab-products') return;
    saveProductsUiState({ scrollY: window.scrollY });
  }, { passive: true });

  window.addEventListener('beforeunload', () => {
    if (getActiveTabTarget() !== '#tab-products') return;
    saveProductsUiState({ scrollY: window.scrollY });
  });

  updateSaveButtonVisibility();

  if (siteTabsElement) {
    siteTabsElement.querySelectorAll('[data-bs-toggle="pill"]').forEach((btn) => {
      btn.addEventListener('shown.bs.tab', (e) => {
        const target = e.target?.getAttribute('data-bs-target');
        if (!target) return;
        try {
          localStorage.setItem(tabsStorageKey, target);
        } catch (_) {}
        if (window.history && typeof window.history.replaceState === 'function') {
          window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}${target}`);
        } else {
          window.location.hash = target;
        }
      });
    });

    const hashTarget = (window.location.hash || '').startsWith('#tab-') ? window.location.hash : '';
    let rememberedTarget = '';
    if (!hashTarget) {
      try {
        const cached = localStorage.getItem(tabsStorageKey) || '';
        if (cached.startsWith('#tab-')) rememberedTarget = cached;
      } catch (_) {}
    }
    const activeTarget = hashTarget || rememberedTarget;
    activateTabByTarget(activeTarget);
    if (activeTarget === '#tab-products') {
      restoreProductsUiState();
    }
  }
})();
</script>

